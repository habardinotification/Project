      sortedDates.forEach(([dateStr, count], i) => { let dayName = new Date(dateStr).toLocaleDateString('ar-SA', { weekday: 'long' }); let bar = '▰'.repeat(Math.round((count / maxDaily) * 35)) + '▱'.repeat(35 - Math.round((count / maxDaily) * 35)) + ` (${count})`; let row = ws6.getRow(3 + i); row.values = [dateStr, dayName, count, bar]; row.height = 22; row.eachCell((cell, col) => { cell.font = col === 4 ? { name: 'Consolas', size: 9, color: { argb: 'FF4472C4' } } : dataFont; cell.alignment = col === 4 ? { horizontal: 'left', vertical: 'middle' } : centerAlign; cell.border = thinBorder; cell.fill = { type: 'pattern', pattern: 'solid', fgColor: { argb: i % 2 === 0 ? 'FFF2F7FB' : 'FFFFFFFF' } }; }); });
      // ورقة7: أفضل 10
      let ws7 = workbook.addWorksheet('أفضل 10 سائقين', { views: [{ rightToLeft: true }] }); ws7.columns = [{ width: 12 }, { width: 15 }, { width: 22 }, { width: 16 }, { width: 30 }, { width: 30 }, { width: 18 }]; ws7.mergeCells('A1:G1'); ws7.getCell('A1').value = '🏆 أفضل 10 سائقين (حسب عدد الرحلات)'; ws7.getCell('A1').font = { ...titleFont, size: 18 }; ws7.getCell('A1').alignment = centerAlign; ws7.getCell('A1').fill = { type: 'pattern', pattern: 'solid', fgColor: { argb: 'FFFFF2CC' } }; ws7.getRow(1).height = 42;
      let thRow = ws7.getRow(2); thRow.values = ['الترتيب', 'رقم السيارة', 'السائق', 'عدد الرحلات', 'المصنع (رود 1)', 'المصنع (رود 2)', 'الميدالية']; thRow.height = 30; thRow.eachCell(cell => { cell.font = headerFont; cell.fill = { type: 'pattern', pattern: 'solid', fgColor: { argb: 'FFBF8F00' } }; cell.alignment = centerAlign; cell.border = thinBorder; });
      let medals = ['🥇 الأول', '🥈 الثاني', '🥉 الثالث']; let medalColors = ['FFFFD700', 'FFC0C0C0', 'FFCD7F32'];
      for (let i = 0; i < Math.min(10, sortedDrivers.length); i++) { let d = sortedDrivers[i]; let f1 = getMostFrequentFactoryForDriverByRoad(d.number, allDistributions, 1); let f2 = getMostFrequentFactoryForDriverByRoad(d.number, allDistributions, 2); let row = ws7.getRow(3 + i); row.values = [i+1, d.number, d.driver, d.total, f1, f2, i < 3 ? medals[i] : '⭐ متميز']; row.height = 32; row.eachCell(cell => { cell.font = { ...dataFont, bold: i < 3, size: i < 3 ? 13 : 11 }; cell.alignment = centerAlign; cell.border = thinBorder; }); if (i < 3) row.eachCell(cell => { cell.fill = { type: 'pattern', pattern: 'solid', fgColor: { argb: medalColors[i] } }; }); else row.eachCell(cell => { cell.fill = { type: 'pattern', pattern: 'solid', fgColor: { argb: i % 2 === 0 ? 'FFFFF2CC' : 'FFFFFFFF' } }; }); }
      // ورقة8: تفاصيل الرحلات
      let ws8 = workbook.addWorksheet('تفاصيل الرحلات', { views: [{ rightToLeft: true }] }); ws8.columns = [{ width: 8 }, { width: 14 }, { width: 14 }, { width: 20 }, { width: 35 }, { width: 15 }, { width: 12 }, { width: 15 }]; ws8.mergeCells('A1:H1'); ws8.getCell('A1').value = '📋 تفاصيل جميع الرحلات (مع التوقيت)'; ws8.getCell('A1').font = { ...titleFont, size: 16 }; ws8.getCell('A1').alignment = centerAlign; ws8.getCell('A1').fill = { type: 'pattern', pattern: 'solid', fgColor: { argb: 'FFD6E4F0' } }; ws8.getRow(1).height = 38;
      let trhRow = ws8.getRow(2); trhRow.values = ['#', 'التاريخ', 'رقم السيارة', 'السائق', 'المصنع', 'نوع البحص', 'الرود', 'التوقيت']; trhRow.height = 28; trhRow.eachCell(cell => { cell.font = headerFont; cell.fill = headerFill; cell.alignment = centerAlign; cell.border = thinBorder; });
      let sortedTrips = [...allDistributions].sort((a,b) => (a.date || '').localeCompare(b.date || ''));
      for (let i = 0; i < sortedTrips.length; i++) { const trip = sortedTrips[i]; const order = reportData.allOrders.find(o => o.id === trip.orderId); const row = ws8.getRow(3 + i); row.values = [i+1, trip.date || '', trip.truck?.number || '', trip.truck?.driver || '', order?.factory || '', order?.material || '', trip.road === 1 ? 'رود 1' : (trip.road === 2 ? 'رود 2' : 'رود ' + trip.road), formatTime(trip.time)]; row.height = 20; let bg = i % 2 === 0 ? 'FFF2F7FB' : 'FFFFFFFF'; row.eachCell(cell => { cell.font = dataFont; cell.alignment = centerAlign; cell.border = thinBorder; cell.fill = { type: 'pattern', pattern: 'solid', fgColor: { argb: bg } }; }); const roadCell = ws8.getCell(`G${3+i}`); roadCell.fill = { type: 'pattern', pattern: 'solid', fgColor: { argb: trip.road === 1 ? 'FFD6E4F0' : (trip.road === 2 ? 'FFFCE4D6' : 'FFE2EFDA') } }; roadCell.font = { ...dataFont, bold: true, color: { argb: trip.road === 1 ? 'FF2E75B6' : (trip.road === 2 ? 'FFED7D31' : 'FF548235') } }; }
      const buffer = await workbook.xlsx.writeBuffer();
      saveAs(new Blob([buffer]), `تقرير_شامل_${dateRange.from}_إلى_${dateRange.to}.xlsx`);
      showToast('✅ تم تصدير التقرير الكامل (8 أوراق)', 'success');
    } catch(e) { console.error(e); showToast('خطأ في التصدير: ' + e.message, 'error'); }
    showLoading(false);
  }

  function exportToPDF() { showToast('جاري تحضير الطباعة...', 'info'); document.querySelectorAll('.tab-content').forEach(t => t.classList.add('active')); setTimeout(() => { window.print(); document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active')); const activeTab = document.querySelector('.tab-btn.active'); if (activeTab) showTab(activeTab.getAttribute('data-tab')); }, 500); }

  async function loadFilters() {
    try {
      const settings = await apiCall('/settings');
      factoriesWithLocation = settings.factories || [];
      const factorySelect = document.getElementById('filterFactory'); const factories = settings.factories || [];
      factories.forEach(f => { const name = typeof f === 'string' ? f : f.name; if (name) { const opt = document.createElement('option'); opt.value = name; opt.textContent = name; factorySelect.appendChild(opt); } });
      const materialSelect = document.getElementById('filterMaterial'); const products = settings.materials || [];
      products.forEach(p => { const name = typeof p === 'string' ? p : p.name; if (name) { const opt = document.createElement('option'); opt.value = name; opt.textContent = name; materialSelect.appendChild(opt); } });
    } catch(e) { console.error('خطأ في تحميل الفلاتر:', e); }
  }

  document.addEventListener('DOMContentLoaded', async () => {
    const today = formatDate(new Date());
    document.getElementById('dateFrom').value = today;
    document.getElementById('dateTo').value = today;
    await loadFilters();
    await loadReport();
    document.getElementById('loadReportBtn').addEventListener('click', loadReport);
    document.getElementById('exportExcelBtn').addEventListener('click', exportFullExcel);
    document.getElementById('printBtn').addEventListener('click', exportToPDF);
    document.querySelectorAll('.quick-filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.getAttribute('data-filter');
        const todayDate = new Date();
        let from, to;
        switch(filter) {
          case 'today': from = to = todayDate; break;
          case 'yesterday': const yesterday = new Date(todayDate); yesterday.setDate(yesterday.getDate() - 1); from = to = yesterday; break;
          case 'week': const weekStart = new Date(todayDate); weekStart.setDate(weekStart.getDate() - weekStart.getDay()); from = weekStart; to = todayDate; break;
          case 'month': from = new Date(todayDate.getFullYear(), todayDate.getMonth(), 1); to = todayDate; break;
          case 'lastMonth': from = new Date(todayDate.getFullYear(), todayDate.getMonth() - 1, 1); to = new Date(todayDate.getFullYear(), todayDate.getMonth(), 0); break;
          default: return;
        }
        document.getElementById('dateFrom').value = formatDate(from);
        document.getElementById('dateTo').value = formatDate(to);
        loadReport();
      });
    });
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => showTab(btn.getAttribute('data-tab')));
    });
  });
</script>
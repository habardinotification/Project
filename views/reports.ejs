<!-- views/reports.ejs -->
<style>
  /* أنماط خاصة بصفحة التقارير – متوافقة مع النظام */
  .filters-section {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .filters-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: flex-end;
  }
  .filter-group {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .filter-group label {
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .filter-group input, .filter-group select {
    padding: 0.5rem 0.8rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border-color);
    background: var(--bg-input);
    color: var(--text-primary);
  }
  .quick-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border-color);
  }
  .quick-filter-btn {
    padding: 0.3rem 0.8rem;
    border: 1px solid var(--border-color);
    border-radius: 40px;
    background: transparent;
    color: var(--text-primary);
    cursor: pointer;
    transition: 0.2s;
  }
  .quick-filter-btn.active, .quick-filter-btn:hover {
    background: var(--primary);
    color: white;
    border-color: var(--primary);
  }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .stat-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 1rem;
    text-align: center;
  }
  .stat-card h3 {
    font-size: 2rem;
    color: var(--primary);
    margin: 0;
  }
  .charts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .chart-container, .chart-full {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 1rem;
  }
  .chart-wrapper {
    height: 280px;
    width: 100%;
  }
  .tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 0.5rem;
  }
  .tab-btn {
    padding: 0.5rem 1rem;
    border: none;
    background: transparent;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: 0.2s;
    color: var(--text-primary);
  }
  .tab-btn.active, .tab-btn:hover {
    background: var(--primary-soft);
    color: var(--primary);
  }
  .tab-content {
    display: none;
  }
  .tab-content.active {
    display: block;
  }
  .badge {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    border-radius: 40px;
    font-size: 0.75rem;
    font-weight: 600;
  }
  .badge-green { background: rgba(56,239,125,0.2); color: #38ef7d; }
  .badge-blue { background: rgba(79,172,254,0.2); color: #4facfe; }
  .badge-purple { background: rgba(240,147,251,0.2); color: #f093fb; }
  .badge-red { background: rgba(245,87,108,0.2); color: #f5576c; }
  .print-section {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }
  @media (max-width: 768px) {
    .charts-grid { grid-template-columns: 1fr; }
    .filters-row { flex-direction: column; align-items: stretch; }
  }
</style>

<div class="filters-section">
  <h3>📅 تحديد الفترة الزمنية</h3>
  <div class="filters-row">
    <div class="filter-group"><label>من تاريخ:</label><input type="date" id="dateFrom"></div>
    <div class="filter-group"><label>إلى تاريخ:</label><input type="date" id="dateTo"></div>
    <div class="filter-group"><label>المصنع:</label><select id="filterFactory"><option value="">الكل</option></select></div>
    <div class="filter-group"><label>نوع البحص:</label><select id="filterMaterial"><option value="">الكل</option></select></div>
    <div class="filter-group"><button class="btn primary" id="loadReportBtn">🔍 عرض التقرير</button></div>
  </div>
  <div class="quick-filters">
    <button class="quick-filter-btn" data-filter="today">📅 اليوم</button>
    <button class="quick-filter-btn" data-filter="yesterday">📅 أمس</button>
    <button class="quick-filter-btn" data-filter="week">📅 هذا الأسبوع</button>
    <button class="quick-filter-btn" data-filter="month">📅 هذا الشهر</button>
    <button class="quick-filter-btn" data-filter="lastMonth">📅 الشهر الماضي</button>
  </div>
</div>

<div class="print-section">
  <button class="btn soft" id="exportExcelBtn">📥 تصدير Excel (8 أوراق)</button>
  <button class="btn soft" id="printBtn">🖨️ طباعة التقرير</button>
</div>

<div class="stats-grid" id="statsGrid">
  <div class="stat-card"><h3 id="statTotalOrders">0</h3><p>📋 إجمالي الطلبات</p></div>
  <div class="stat-card"><h3 id="statDistributed">0</h3><p>🚚 الطلبات الموزعة</p></div>
  <div class="stat-card"><h3 id="statPending">0</h3><p>⏳ في الانتظار</p></div>
  <div class="stat-card"><h3 id="statFactories">0</h3><p>🏭 عدد المصانع</p></div>
  <div class="stat-card"><h3 id="statTrucks">0</h3><p>🚛 سيارات نشطة</p></div>
  <div class="stat-card"><h3 id="statMaterials">0</h3><p>📦 أنواع بحص</p></div>
</div>

<div class="tabs">
  <button class="tab-btn active" data-tab="overview">📊 نظرة عامة</button>
  <button class="tab-btn" data-tab="factories">🏭 تقرير المصانع</button>
  <button class="tab-btn" data-tab="materials">📦 تقرير البحص</button>
  <button class="tab-btn" data-tab="trucks">🚛 تقرير السيارات</button>
  <button class="tab-btn" data-tab="daily">📅 التقرير اليومي</button>
  <button class="tab-btn" data-tab="allOrders">📋 كل الطلبات</button>
</div>

<div id="tab-overview" class="tab-content active">
  <div class="charts-grid">
    <div class="chart-container"><h3>📈 توزيع الطلبات حسب المصنع</h3><div class="chart-wrapper"><canvas id="factoriesChart"></canvas></div></div>
    <div class="chart-container"><h3>📦 توزيع الطلبات حسب نوع البحص</h3><div class="chart-wrapper"><canvas id="materialsChart"></canvas></div></div>
  </div>
  <div class="chart-full"><h3>📊 توزيع الطلبات يومياً</h3><div class="chart-wrapper"><canvas id="dailyChart"></canvas></div></div>
  <div class="charts-grid">
    <div class="chart-container"><h3>🚛 أكثر السيارات نشاطاً</h3><div class="chart-wrapper"><canvas id="trucksChart"></canvas></div></div>
    <div class="chart-container"><h3>📊 نسبة التوزيع مقابل الطلبات</h3><div class="chart-wrapper"><canvas id="distributionRatioChart"></canvas></div></div>
  </div>
</div>

<div id="tab-factories" class="tab-content">
  <div class="charts-grid">
    <div class="chart-container"><h3>📊 طلبات كل مصنع</h3><div class="chart-wrapper"><canvas id="factoryDetailChart"></canvas></div></div>
    <div class="chart-container"><h3>📊 نسبة كل مصنع من الإجمالي</h3><div class="chart-wrapper"><canvas id="factoryPieChart"></canvas></div></div>
  </div>
  <div class="detail-section"><h3>📋 تفاصيل طلبات المصانع</h3><div class="table-wrap"><table id="factoriesTable"><thead><tr><th>#</th><th>المصنع</th><th>عدد الطلبات</th><th>تم التوزيع</th><th>في الانتظار</th><th>النسبة من الإجمالي</th></tr></thead><tbody id="factoriesTableBody"></tbody></table></div></div>
</div>

<div id="tab-materials" class="tab-content">
  <div class="charts-grid">
    <div class="chart-container"><h3>📊 طلبات كل نوع بحص</h3><div class="chart-wrapper"><canvas id="materialDetailChart"></canvas></div></div>
    <div class="chart-container"><h3>📊 نسبة كل نوع بحص</h3><div class="chart-wrapper"><canvas id="materialPieChart"></canvas></div></div>
  </div>
  <div class="detail-section"><h3>📋 تفاصيل أنواع البحص</h3><div class="table-wrap"><table id="materialsTable"><thead><tr><th>#</th><th>نوع البحص</th><th>عدد الطلبات</th><th>عدد المصانع الطالبة</th><th>النسبة من الإجمالي</th></tr></thead><tbody id="materialsTableBody"></tbody></table></div></div>
  <div class="detail-section"><h3>📋 تفصيل البحص حسب المصنع</h3><div class="table-wrap"><table id="materialsByFactoryTable"><thead><tr><th>#</th><th>المصنع</th><th>نوع البحص</th><th>عدد الطلبات</th></tr></thead><tbody id="materialsByFactoryBody"></tbody></table></div></div>
</div>

<div id="tab-trucks" class="tab-content">
  <div class="charts-grid">
    <div class="chart-container"><h3>📊 رحلات كل سيارة</h3><div class="chart-wrapper"><canvas id="truckDetailChart"></canvas></div></div>
    <div class="chart-container"><h3>📊 أنواع البحص لكل سيارة</h3><div class="chart-wrapper"><canvas id="truckMaterialChart"></canvas></div></div>
  </div>
  <div class="detail-section"><h3>📋 تفاصيل رحلات السيارات</h3><div class="table-wrap"><table id="trucksTable"><thead><tr><th>#</th><th>رقم السيارة</th><th>اسم السائق</th><th>عدد الرحلات</th><th>المصانع</th><th>أنواع البحص</th></tr></thead><tbody id="trucksTableBody"></tbody></table></div></div>
</div>

<div id="tab-daily" class="tab-content">
  <div class="chart-full"><h3>📊 مخطط الطلبات اليومية</h3><div class="chart-wrapper"><canvas id="dailyDetailChart"></canvas></div></div>
  <div class="detail-section"><h3>📋 تفاصيل كل يوم</h3><div class="table-wrap"><table id="dailyTable"><thead><tr><th>#</th><th>التاريخ</th><th>اليوم</th><th>عدد الطلبات</th><th>تم التوزيع</th><th>في الانتظار</th><th>عدد السيارات</th></tr></thead><tbody id="dailyTableBody"></tbody></table></div></div>
</div>

<div id="tab-allOrders" class="tab-content">
  <div class="detail-section"><h3>📋 جميع الطلبات (<span id="allOrdersCount">0</span>)</h3><div class="table-wrap"><table id="allOrdersTable"><thead><tr><th>#</th><th>التاريخ</th><th>المصنع</th><th>نوع البحص</th><th>التوقيت</th><th>الحالة</th><th>السيارة</th></tr></thead><tbody id="allOrdersBody"></tbody></table></div></div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/exceljs@4.4.0/dist/exceljs.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/file-saver@2.0.5/dist/FileSaver.min.js"></script>
<script>
  const API_BASE = '/api';
  let charts = {};
  let reportData = { allOrders: [], allDistributions: [], dateRange: { from: '', to: '' }, dates: [] };
  let factoriesWithLocation = [];

  async function apiCall(endpoint, method = 'GET', data = null) {
    const options = { method, headers: { 'Content-Type': 'application/json' }, credentials: 'include' };
    if (data) options.body = JSON.stringify(data);
    const res = await fetch(`${API_BASE}${endpoint}`, options);
    if (res.status === 401) { window.location.href = '/login'; throw new Error('غير مصرح'); }
    if (!res.ok) throw new Error(await res.text());
    return res.json();
  }

  function showToast(msg, type = 'success') {
    let container = document.getElementById('toastContainer');
    if (!container) {
      container = document.createElement('div');
      container.id = 'toastContainer';
      container.style.position = 'fixed';
      container.style.top = '20px';
      container.style.left = '20px';
      container.style.zIndex = '3000';
      document.body.appendChild(container);
    }
    const toast = document.createElement('div');
    toast.className = `toast ${type}`;
    toast.innerText = msg;
    container.appendChild(toast);
    setTimeout(() => toast.remove(), 4000);
  }

  function showLoading(show) {
    let loader = document.getElementById('globalLoader');
    if (!loader) {
      loader = document.createElement('div');
      loader.id = 'globalLoader';
      loader.style.position = 'fixed';
      loader.style.top = '0';
      loader.style.left = '0';
      loader.style.width = '100%';
      loader.style.height = '100%';
      loader.style.background = 'rgba(0,0,0,0.6)';
      loader.style.display = 'flex';
      loader.style.alignItems = 'center';
      loader.style.justifyContent = 'center';
      loader.style.zIndex = '9999';
      loader.innerHTML = '<div class="spinner"></div>';
      document.body.appendChild(loader);
    }
    loader.style.display = show ? 'flex' : 'none';
  }

  function formatDate(date) { return date.toISOString().split('T')[0]; }
  function getArabicDay(dateStr) { const days = ['الأحد', 'الإثنين', 'الثلاثاء', 'الأربعاء', 'الخميس', 'الجمعة', 'السبت']; return days[new Date(dateStr).getDay()]; }
  function getDatesBetween(startDate, endDate) { const dates = []; const start = new Date(startDate); const end = new Date(endDate); const current = new Date(start); while (current <= end) { dates.push(formatDate(current)); current.setDate(current.getDate() + 1); } return dates; }

  function showTab(tabName) {
    document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.getElementById(`tab-${tabName}`).classList.add('active');
    document.querySelector(`.tab-btn[data-tab="${tabName}"]`).classList.add('active');
  }

  async function loadReport() {
    const dateFrom = document.getElementById('dateFrom').value;
    const dateTo = document.getElementById('dateTo').value;
    const filterFactory = document.getElementById('filterFactory').value;
    const filterMaterial = document.getElementById('filterMaterial').value;
    if (!dateFrom || !dateTo) { showToast('يرجى تحديد الفترة الزمنية', 'warning'); return; }
    if (dateFrom > dateTo) { showToast('تاريخ البداية يجب أن يكون قبل تاريخ النهاية', 'error'); return; }
    showLoading(true);
    try {
      const dates = getDatesBetween(dateFrom, dateTo);
      let allOrders = [];
      let allDistributions = [];
      for (const date of dates) {
        try {
          const dayData = await apiCall(`/day/${date}`);
          const orders = (dayData.orders || []).map(o => ({ ...o, date }));
          const distributions = (dayData.distribution || []).map(d => ({ ...d, date }));
          allOrders.push(...orders);
          allDistributions.push(...distributions);
        } catch(e) { console.warn(`فشل جلب بيانات ${date}:`, e); }
      }
      if (filterFactory) allOrders = allOrders.filter(o => o.factory === filterFactory);
      if (filterMaterial) allOrders = allOrders.filter(o => o.material === filterMaterial);
      reportData = { allOrders, allDistributions, dateRange: { from: dateFrom, to: dateTo }, dates };
      updateStats();
      renderOverviewCharts();
      renderFactoriesTab();
      renderMaterialsTab();
      renderTrucksTab();
      renderDailyTab();
      renderAllOrdersTab();
      showToast(`تم تحميل تقرير ${dates.length} يوم - ${allOrders.length} طلب`, 'success');
    } catch(e) { showToast('خطأ في تحميل البيانات: ' + e.message, 'error'); }
    showLoading(false);
  }

  function updateStats() {
    const { allOrders, allDistributions } = reportData;
    const distributedMap = new Map();
    allDistributions.forEach(d => { if (!distributedMap.has(d.orderId)) distributedMap.set(d.orderId, d); });
    const distributedOrderIds = new Set(distributedMap.keys());
    const totalOrders = allOrders.length;
    const distributed = distributedOrderIds.size;
    const pending = Math.max(0, totalOrders - distributed);
    const factoriesSet = new Set(allOrders.map(o => o.factory).filter(Boolean));
    const materialsSet = new Set(allOrders.map(o => o.material).filter(Boolean));
    const trucksSet = new Set(Array.from(distributedMap.values()).map(d => d.truck?.number).filter(Boolean));
    document.getElementById('statTotalOrders').textContent = totalOrders;
    document.getElementById('statDistributed').textContent = distributed;
    document.getElementById('statPending').textContent = pending;
    document.getElementById('statFactories').textContent = factoriesSet.size;
    document.getElementById('statTrucks').textContent = trucksSet.size;
    document.getElementById('statMaterials').textContent = materialsSet.size;
  }

  const chartColors = ['#667eea', '#f5576c', '#38ef7d', '#4facfe', '#f093fb', '#ffeaa7', '#fd79a8', '#a29bfe', '#00cec9', '#e17055', '#6c5ce7', '#00b894', '#fdcb6e', '#e84393', '#0984e3', '#55efc4', '#fab1a0', '#74b9ff', '#b2bec3', '#dfe6e6'];
  function destroyChart(name) { if (charts[name]) { charts[name].destroy(); charts[name] = null; } }

  function renderOverviewCharts() {
    const { allOrders, allDistributions, dates } = reportData;
    const factoryStats = {}; allOrders.forEach(o => { const f = o.factory || 'غير محدد'; factoryStats[f] = (factoryStats[f] || 0) + 1; });
    destroyChart('factoriesChart');
    charts.factoriesChart = new Chart(document.getElementById('factoriesChart'), { type: 'bar', data: { labels: Object.keys(factoryStats), datasets: [{ label: 'عدد الطلبات', data: Object.values(factoryStats), backgroundColor: 'rgba(102,126,234,0.8)' }] }, options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { labels: { color: '#fff' } } }, scales: { x: { ticks: { color: '#a8b2d1' } }, y: { ticks: { color: '#a8b2d1' }, beginAtZero: true } } } });
    const materialStats = {}; allOrders.forEach(o => { const m = o.material || 'غير محدد'; materialStats[m] = (materialStats[m] || 0) + 1; });
    destroyChart('materialsChart');
    charts.materialsChart = new Chart(document.getElementById('materialsChart'), { type: 'doughnut', data: { labels: Object.keys(materialStats), datasets: [{ data: Object.values(materialStats), backgroundColor: chartColors.slice(0, Object.keys(materialStats).length) }] }, options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom', labels: { color: '#fff' } } } } });
    if (dates && dates.length) { const dailyStats = {}; dates.forEach(d => dailyStats[d] = 0); allOrders.forEach(o => { if (dailyStats.hasOwnProperty(o.date)) dailyStats[o.date]++; }); destroyChart('dailyChart'); charts.dailyChart = new Chart(document.getElementById('dailyChart'), { type: 'line', data: { labels: Object.keys(dailyStats), datasets: [{ label: 'عدد الطلبات', data: Object.values(dailyStats), borderColor: '#667eea', backgroundColor: 'rgba(102,126,234,0.1)', fill: true, tension: 0.4 }] }, options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { labels: { color: '#fff' } } }, scales: { x: { ticks: { color: '#a8b2d1' } }, y: { ticks: { color: '#a8b2d1' }, beginAtZero: true } } } }); }
    const distributedMap = new Map(); allDistributions.forEach(d => { if (!distributedMap.has(d.orderId)) distributedMap.set(d.orderId, d); }); const uniqueDistributions = Array.from(distributedMap.values()); const truckStats = {}; uniqueDistributions.forEach(d => { const tn = d.truck?.number || 'غير محدد'; truckStats[tn] = (truckStats[tn] || 0) + 1; }); const sortedTrucks = Object.entries(truckStats).sort((a,b)=>b[1]-a[1]).slice(0,10); destroyChart('trucksChart'); charts.trucksChart = new Chart(document.getElementById('trucksChart'), { type: 'bar', data: { labels: sortedTrucks.map(t=>t[0]), datasets: [{ label: 'عدد الرحلات', data: sortedTrucks.map(t=>t[1]), backgroundColor: chartColors.slice(0, sortedTrucks.length) }] }, options: { responsive: true, maintainAspectRatio: false, indexAxis: 'y', plugins: { legend: { labels: { color: '#fff' } } }, scales: { x: { ticks: { color: '#a8b2d1' }, beginAtZero: true }, y: { ticks: { color: '#a8b2d1' } } } } });
    const totalOrders = allOrders.length; const distributed = uniqueDistributions.length; const pending = Math.max(0, totalOrders - distributed); destroyChart('distributionRatioChart'); charts.distributionRatioChart = new Chart(document.getElementById('distributionRatioChart'), { type: 'doughnut', data: { labels: ['تم التوزيع', 'في الانتظار'], datasets: [{ data: [distributed, pending], backgroundColor: ['#38ef7d', '#f5576c'] }] }, options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom', labels: { color: '#fff' } } } } });
  }

  function renderFactoriesTab() {
    const { allOrders, allDistributions } = reportData;
    const distributedMap = new Map(); allDistributions.forEach(d => { if (!distributedMap.has(d.orderId)) distributedMap.set(d.orderId, d); }); const distributedOrderIds = new Set(distributedMap.keys());
    const factoryStats = {}; allOrders.forEach(o => { const f = o.factory || 'غير محدد'; if (!factoryStats[f]) factoryStats[f] = { total: 0, distributed: 0 }; factoryStats[f].total++; if (distributedOrderIds.has(o.id)) factoryStats[f].distributed++; });
    const labels = Object.keys(factoryStats); const totals = labels.map(f => factoryStats[f].total); const distrib = labels.map(f => factoryStats[f].distributed); const totalAll = allOrders.length;
    destroyChart('factoryDetailChart'); charts.factoryDetailChart = new Chart(document.getElementById('factoryDetailChart'), { type: 'bar', data: { labels, datasets: [{ label: 'إجمالي الطلبات', data: totals, backgroundColor: 'rgba(102,126,234,0.8)' }, { label: 'تم التوزيع', data: distrib, backgroundColor: 'rgba(56,239,125,0.8)' }] }, options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { labels: { color: '#fff' } } }, scales: { x: { ticks: { color: '#a8b2d1' } }, y: { ticks: { color: '#a8b2d1' }, beginAtZero: true } } } });
    destroyChart('factoryPieChart'); charts.factoryPieChart = new Chart(document.getElementById('factoryPieChart'), { type: 'pie', data: { labels, datasets: [{ data: totals, backgroundColor: chartColors.slice(0, labels.length) }] }, options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom', labels: { color: '#fff' } } } } });
    document.getElementById('factoriesTableBody').innerHTML = labels.map((f,i) => { const total = factoryStats[f].total; const dist = factoryStats[f].distributed; const pend = total - dist; const pct = totalAll > 0 ? ((total / totalAll) * 100).toFixed(1) : 0; return `<tr><td>${i+1}</td><td><strong>${f}</strong></td><td><span class="badge badge-blue">${total}</span></td><td><span class="badge badge-green">${dist}</span></td><td><span class="badge ${pend > 0 ? 'badge-red' : 'badge-green'}">${pend}</span></td><td>${pct}%</td></tr>`; }).join('');
  }

  function renderMaterialsTab() {

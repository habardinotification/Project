        <label style="font-size: 0.8rem;">🏭 المصنع</label>
        <div id="editFactoryContainer"></div>
      </div>
      <div class="form-group" style="margin-bottom: 0.8rem;">
        <label style="font-size: 0.8rem;">🧱 نوع البحص</label>
        <select id="editOrderMaterial" class="form-control" style="padding: 0.4rem;"></select>
      </div>
      <div class="form-group" style="margin-bottom: 0.8rem;">
        <label style="font-size: 0.8rem;">⏰ التوقيت</label>

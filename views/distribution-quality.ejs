  <button class="tab-btn" data-tab="cancel">🗑️ حالات الإلغاء</button>
</div>

<div id="manualTab" class="violations-section">
  <div id="manualViolationsList"></div>
</div>
<div id="rejectTab" class="violations-section" style="display:none;">
  <div id="rejectViolationsList"></div>
</div>
<div id="cancelTab" class="violations-section" style="display:none;">

<style>
  .main { padding: 1rem; min-height: 100vh; }
  .summary-bar {
    background: var(--bg-card); border: 1px solid var(--border-color);
    border-radius: 12px; padding: 0.7rem 1.2rem; margin-bottom: 1.5rem;
    display: flex; gap: 2rem; flex-wrap: wrap; align-items: center; justify-content: center;
  }
  .summary-item { font-weight: 600; font-size: 0.95rem; }
  .summary-item span { color: var(--primary); font-weight: 800; }
  .tab-btn {
    background: var(--bg-card); border: 1px solid var(--border-color);
    padding: 0.4rem 1.2rem; border-radius: 40px; cursor: pointer; font-weight: 600; font-size: 0.85rem; color: var(--text-primary);
  }
  .tab-btn.active { background: var(--primary); color: white; border-color: var(--primary); }
  .sync-btn { background: #db2777; color: white; border: none; padding: 0.4rem 1rem; border-radius: 40px; cursor: pointer; display: inline-flex; align-items: center; gap: 0.3rem; }
  .save-db-btn { background: #22c55e; color: white; border: none; padding: 0.4rem 1rem; border-radius: 40px; cursor: pointer; display: inline-flex; align-items: center; gap: 0.3rem; }
  .suggestion-buttons { display: flex; gap: 0.3rem; justify-content: center; }
  .approve-btn, .reject-btn, .cancel-btn { cursor: pointer; font-size: 1.2rem; padding: 0.2rem 0.5rem; border: none; border-radius: 8px; }
  .approve-btn { background: #22c55e; color: white; }
  .reject-btn { background: #ef4444; color: white; }
  .cancel-btn { background: #f59e0b; color: white; }
  .modal { display: none; position: fixed; top:0; left:0; width:100%; height:100%; background: rgba(0,0,0,0.6); align-items:center; justify-content:center; z-index:10000; }
  .modal.active { display:flex; }
  .modal-content { background: var(--bg-card); border-radius: 20px; padding: 1.5rem; width: 90%; max-width: 450px; }
  .incoming-row { background: #f0f9ff; border-right: 3px solid var(--primary); }
  .arrived-row { background: #fef3c7; border-right: 3px solid #f59e0b; }
  .distributed-row { background: #ecfdf5; }
  .no-suggestion { color: #9ca3af; font-style: italic; }
  .text-sm { font-size: 0.9rem; }
  .time-arrived { color: #b45309; font-weight: bold; }
  .alert-offline { background: #fee2e2; border: 1px solid #ef4444; color: #b91c1c; padding: 0.5rem 1rem; border-radius: 8px; margin-bottom: 1rem; display: none; align-items: center; gap: 0.5rem; }
  .alert-offline.show { display: flex; }
  .btn-sm { padding: 0.3rem 0.8rem; font-size: 0.8rem; }
  .table-wrap { overflow-x: auto; }
  table { width: 100%; border-collapse: collapse; }
  th, td { padding: 0.75rem; text-align: center; border-bottom: 1px solid var(--border-color); }
  th { background: var(--primary-bg); font-weight: 600; }
  .form-control {
    padding: 0.5rem;
    border-radius: 0.6rem;
    border: 1px solid var(--border-color);
    background: var(--bg-input);
    color: var(--text-primary);
    font-family: inherit;
    font-size: 0.9rem;
  }
  .form-control:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 2px var(--primary-soft);
  }
  label {
    display: block;
    margin-bottom: 0.25rem;
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--text-muted);
  }
  .date-section label {
    display: inline-block;
    margin-left: 0.5rem;
  }
  .notification {
    position: fixed;
    bottom: 20px;
    right: 20px;
    padding: 0.75rem 1.5rem;
    border-radius: 2rem;
    z-index: 10001;
    font-weight: 600;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    animation: slideIn 0.3s ease;
  }
  .notification.success { background: #22c55e; color: white; }
  .notification.error { background: #ef4444; color: white; }
  .notification.info { background: #3b82f6; color: white; }
  @keyframes slideIn {
    from { transform: translateX(100%); opacity: 0; }
    to { transform: translateX(0); opacity: 1; }
  }
  @media (max-width: 768px) {
    th, td { font-size: 0.75rem; padding: 0.5rem; }
    .suggestion-buttons { flex-direction: column; gap: 0.2rem; }
    .summary-bar { gap: 1rem; }
  }
</style>

<div class="section-head"><h2>🚚 توزيع ذكي – الفترة من 8ص إلى 12م</h2></div>

<div id="serverOfflineAlert" class="alert-offline">
  <span>⚠️ تعذر الاتصال بالخادم.</span>
  <button onclick="location.reload()" class="btn soft btn-sm">إعادة تحميل</button>
</div>

<div class="date-section card" style="display: flex; justify-content: space-between; flex-wrap: wrap; gap: 1rem; margin-bottom: 1.5rem;">
  <div>
    <label for="orderDate">📅 تاريخ العمل:</label>
    <input type="date" id="orderDate" class="form-control">
  </div>
  <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center;">
    <button class="btn soft print-btn" onclick="window.print()">🖨️ طباعة</button>
    <button class="sync-btn" id="syncGmailBtn"><i class="fas fa-envelope"></i> مزامنة Gmail</button>
    <button class="save-db-btn" id="saveToDbBtn"><i class="fas fa-database"></i> حفظ في قاعدة البيانات</button>
  </div>
</div>

<div class="summary-bar" id="summaryBar">
  <div class="summary-item">🚛 سيارات غير موزعة: <span id="summaryTrucks">0</span></div>
  <div class="summary-item">📋 طلبات غير موزعة: <span id="summaryOrders">0</span></div>
  <div class="summary-item">✅ توزيعات اليوم: <span id="summaryDistributed">0</span></div>
</div>

<div class="tabs-container" style="margin: 1rem 0;">
  <div class="tab-buttons" style="display: flex; gap: 0.5rem; margin-bottom: 1rem;">
    <button class="tab-btn active" data-tab="incoming">🚚 السيارات القادمة والواصلة</button>
    <button class="tab-btn" data-tab="distributed">✅ الموزعة</button>
    <button class="tab-btn" data-tab="orders">📋 الطلبات غير الموزعة</button>
  </div>

  <div class="table-wrap tab-panel" id="panel-incoming">
    <table>
      <thead>
        <tr><th>رقم السيارة</th><th>السائق</th><th>الوقت (متبقي/منذ الوصول)</th><th>المقترح (مصنع / بحص / مسافة)</th><th>إجراء</th></tr>
      </thead>
      <tbody id="incomingBody"></tbody>
    </table>
  </div>

  <div class="table-wrap tab-panel" id="panel-distributed" style="display:none;">
    <table>
      <thead>
        <tr><th>رقم السيارة</th><th>السائق</th><th>المصنع</th><th>نوع البحص</th><th>المسافة</th><th>الرود</th><th>إجراء</th></tr>
      </thead>
      <tbody id="distributedBody"></tbody>
    </table>
  </div>

  <div class="table-wrap tab-panel" id="panel-orders" style="display:none;">
    <table>
      <thead>
        <tr><th>#</th><th>المصنع</th><th>نوع البحص</th><th>المسافة (كم)</th><th>الوقت</th><th>توزيع يدوي</th></tr>
      </thead>
      <tbody id="ordersBody"></tbody>
    </table>
  </div>
</div>

<!-- النوافذ المنبثقة -->
<div class="modal" id="rejectReasonModal">
  <div class="modal-content">
    <h3>❌ سبب رفض التوزيع</h3>
    <div class="form-group">
      <label for="rejectReason">السبب:</label>
      <textarea id="rejectReason" rows="3" class="form-control" style="width:100%;"></textarea>
    </div>
    <div style="display:flex; gap:1rem; justify-content:flex-end; margin-top:1rem;">
      <button class="btn soft" id="cancelRejectBtn">إلغاء</button>
      <button class="btn danger" id="submitRejectBtn">تسجيل الرفض</button>
    </div>
  </div>
</div>

<div class="modal" id="cancelDistModal">
  <div class="modal-content">
    <h3>⚠️ إلغاء توزيع</h3>
    <p>هل أنت متأكد من إلغاء هذا التوزيع؟</p>
    <div class="form-group">
      <label for="cancelReason">سبب الإلغاء:</label>
      <textarea id="cancelReason" rows="3" class="form-control" style="width:100%;"></textarea>
    </div>
    <div style="display:flex; gap:1rem; justify-content:flex-end; margin-top:1rem;">
      <button class="btn soft" id="cancelCancelBtn">تراجع</button>
      <button class="btn danger" id="submitCancelBtn">تأكيد الإلغاء</button>
    </div>
  </div>
</div>

<div class="modal" id="manualDistModal">
  <div class="modal-content">
    <h3>🖐️ توزيع يدوي للطلب</h3>
    <p id="manualAdvice" class="text-sm"></p>
    <div id="manualChoiceSection">
      <div style="display: flex; gap: 1rem; justify-content: center; margin-bottom: 1rem;">
        <button class="btn primary" id="acceptManualAdvice">✅ نعم، قبول النصيحة</button>
        <button class="btn danger soft" id="rejectManualAdvice">❌ لا، أختار بنفسي</button>
      </div>
    </div>
    <div id="manualCustomSection" style="display:none;">
      <div class="form-group">
        <label for="manualTruckSelect">اختر سيارة:</label>
        <select id="manualTruckSelect" class="form-control"></select>
      </div>
      <div class="form-group">
        <label for="manualCustomReason">سبب اختيار سيارة أخرى:</label>
        <input type="text" id="manualCustomReason" placeholder="سبب التغيير" class="form-control">
      </div>
      <button class="btn primary" id="confirmManualCustom">توزيع يدوي</button>
    </div>
    <div style="margin-top:1rem; text-align: left;">
      <button class="btn soft" id="closeManualModalBtn">إغلاق</button>
    </div>
  </div>
</div>

<div class="modal" id="saveConfirmModal">
  <div class="modal-content">
    <h3>💾 حفظ البيانات في قاعدة البيانات</h3>
    <p>سيتم حفظ جميع الطلبات والتوزيعات ليوم <strong id="confirmDate"></strong> في قاعدة البيانات.</p>
    <p style="font-size: 0.85rem; color: var(--text-muted);">يمكنك استرجاع هذه البيانات لاحقاً من التقارير.</p>
    <div style="display: flex; gap: 1rem; justify-content: center; margin-top: 1.5rem;">
      <button class="btn primary" id="confirmSaveBtn">✅ نعم، حفظ</button>
      <button class="btn soft" id="cancelSaveBtn">إلغاء</button>
    </div>
  </div>
</div>

<script>
  (function() {
    const API_BASE = '/api';
    let todayOrders = [], todayDistribution = [], currentDate = '';
    let yesterdayDistribution = [];
    let factoryDistances = {};
    let incomingTrucksAll = [];
    let allIncomingRaw = [];
    let currentTab = 'incoming';
    let rejectTruckId = null;
    let cancelOrderId = null;
    let manualOrder = null;
    let consecutiveFailures = 0;
    let autoRefreshInterval = null;

    let fleetCodes = [];
    let fleetPlateByCode = {};
    let fleetDriverByCode = {};
    let truckSuffixes = {};

    // دالة عرض الإشعارات
    function showNotification(message, type = 'success') {
      const notification = document.createElement('div');
      notification.className = `notification ${type}`;
      notification.textContent = message;
      document.body.appendChild(notification);
      setTimeout(() => {
        notification.style.opacity = '0';
        setTimeout(() => notification.remove(), 300);
      }, 3000);
    }

    async function loadFleetFromAPI() {
      try {
        const res = await fetch('/api/trucks', { credentials: 'include' });
        if (!res.ok) throw new Error('فشل جلب السيارات');
        const trucks = await res.json();
        if (!Array.isArray(trucks)) throw new Error('بيانات غير صالحة');

        fleetCodes = [];
        fleetPlateByCode = {};
        fleetDriverByCode = {};
        truckSuffixes = {};

        trucks.forEach(t => {
          const number = (t.truck_number || t.number || '').trim();
          if (!number) return;
          fleetCodes.push(number);

          const plate = (t.plate_number || t.plate || '').trim();
          fleetPlateByCode[number] = plate;
          const parts = plate.split(' ');
          const suffix = parts.length > 1 ? parts.slice(1).join(' ') : '';
          if (suffix) truckSuffixes[number] = suffix;

          const driver = (t.driver_name || t.driver || '').trim();
          if (driver) fleetDriverByCode[number] = driver;
        });
      } catch(e) {
        console.warn('⚠️ تعذر تحميل الأسطول من API:', e.message);
      }
    }

    function formatTruckNumber(numberStr) {
      if (!numberStr) return '';
      const num = numberStr.trim();
      const suffix = truckSuffixes[num];
      return suffix ? num + ' ' + suffix : num;
    }

    function getDriverFromFleet(truckNumber) {
      return fleetDriverByCode[truckNumber] || '';
    }

    function getYesterdayStr() {
      const d = new Date(currentDate);
      d.setDate(d.getDate() - 1);
      return d.toISOString().slice(0,10);
    }

    function showOfflineAlert() {
      const alert = document.getElementById('serverOfflineAlert');
      if (alert) alert.classList.add('show');
    }

    function hideOfflineAlert() {
      const alert = document.getElementById('serverOfflineAlert');
      if (alert) alert.classList.remove('show');
      consecutiveFailures = 0;
    }

    async function apiCall(ep, method='GET', data=null) {
      const opts = { method, headers: {'Content-Type':'application/json'}, credentials:'include' };
      if(data) opts.body = JSON.stringify(data);
      try {
        const r = await fetch(API_BASE + ep, opts);
        if(r.status === 401) window.location.href = '/login';
        if(!r.ok) throw new Error(await r.text());
        hideOfflineAlert();
        return r.json();
      } catch(e) {
        console.error('API call failed (' + ep + '):', e.message);
        consecutiveFailures++;
        if (consecutiveFailures >= 2) {
          showOfflineAlert();
          if (autoRefreshInterval) {
            clearInterval(autoRefreshInterval);
            autoRefreshInterval = null;
          }
        }
        throw e;
      }
    }

    async function loadFactoryDistances() {
      try {
        const res = await fetch('/api/factories', { credentials: 'include' });
        if (!res.ok) throw new Error('فشل جلب المصانع');
        const factories = await res.json();
        if (!Array.isArray(factories) || factories.length === 0) throw new Error('لا توجد مصانع');
        factoryDistances = {};
        factories.forEach(f => {
          const name = (f.name || '').trim();
          const dist = f.distance_km != null ? Number(f.distance_km) : 0;
          if (name) factoryDistances[name] = dist;
        });
      } catch(e) {
        console.error('تعذر تحميل مسافات المصانع:', e);
      }
    }

    function getDistance(factoryName) {
      const name = (factoryName || '').trim();
      return factoryDistances.hasOwnProperty(name) ? factoryDistances[name] : null;
    }

    function formatDistance(distance) {
      if (distance === null || distance === undefined) return '<span style="color:red">غير محدد</span>';
      if (distance === 0) return '<span style="color:orange">0 كم</span>';
      return distance.toFixed(1) + ' كم';
    }

    function filterByTimeWindow(trucks, dateStr) {
      const start = new Date(dateStr + 'T08:00:00');
      const end = new Date(dateStr + 'T23:59:59');
      return trucks.filter(t => {
        const arr = new Date(t.expected_arrival);
        return arr >= start && arr <= end;
      });
    }

    function driverStatsFromDist(distArray) {
      const map = {};
      distArray.forEach(d => {
        if(!d.truck || !d.truck.number) return;
        const num = d.truck.number;
        if(!map[num]) map[num] = { trips:0, totalDist:0, lastDist:0 };
        map[num].trips += 1;
        const dist = getDistance(d.factory);
        if (dist !== null) {
          map[num].totalDist += dist;
          map[num].lastDist = dist;
        }
      });
      return map;
    }

    function getUndistributedOrders() {
      const distributedIds = new Set(todayDistribution.map(d => d.orderId));
      return todayOrders.filter(o => !distributedIds.has(o.id));
    }

    function suggestOrderForTruck(truck, undOrders, yStats) {
      if (!undOrders.length) return null;
      
      const y = yStats[truck.truck_number] || {};
      const lastDist = y.lastDist || 0;
      
      let pref = 'balanced';
      if (lastDist > 300) pref = 'nearest';
      else if (lastDist < 200 && lastDist > 0) pref = 'farthest';
      
      const scored = undOrders.map(o => {
        const d = getDistance(o.factory);
        if (d === null) return { order: o, score: -1 };
        let score = 0;
        if (pref === 'nearest') score = 1000 - d;
        else if (pref === 'farthest') score = d;
        else score = 500 - (y.trips || 0) * 10;
        return { order: o, score: score };
      });
      scored.sort((a,b) => b.score - a.score);
      return scored[0] && scored[0].score > -1 ? scored[0].order : null;
    }

    // دالة حفظ البيانات في قاعدة البيانات
    async function saveToDatabase() {
      try {
        const dataToSave = {
          orders: todayOrders,
          distribution: todayDistribution
        };
        
        const response = await fetch(`/api/day/${currentDate}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify(dataToSave)
        });
        
        if (!response.ok) throw new Error('فشل الحفظ');
        
        const result = await response.json();
        showNotification(`✅ تم حفظ ${todayOrders.length} طلب و ${todayDistribution.length} توزيع في قاعدة البيانات`, 'success');
        return true;
      } catch (error) {
        console.error('خطأ في الحفظ:', error);
        showNotification('❌ فشل حفظ البيانات في قاعدة البيانات', 'error');
        return false;
      }
    }

    function renderCurrentTab() {
      const undOrders = getUndistributedOrders();
      const yStats = driverStatsFromDist(yesterdayDistribution);
      const now = new Date();
      const cutoff = new Date(now.getTime() + 60 * 60000);
      const notAssigned = incomingTrucksAll.filter(t => !t.assigned);
      const arrived = notAssigned.filter(t => new Date(t.expected_arrival) <= now);
      const pending = notAssigned.filter(t => new Date(t.expected_arrival) > now && new Date(t.expected_arrival) <= cutoff);
      const allIncoming = [...arrived, ...pending];
      const distributed = todayDistribution;

      document.getElementById('summaryTrucks').innerText = allIncoming.length;
      document.getElementById('summaryOrders').innerText = undOrders.length;
      document.getElementById('summaryDistributed').innerText = distributed.length;

      // سيارات قادمة
      let incHtml = '';
      if (!allIncoming.length) {
        incHtml = '<tr><td colspan="5">لا توجد سيارات (ضمن الفترة 8ص-12م)</td></tr>';
      } else {
        allIncoming.forEach(t => {
          const arr = new Date(t.expected_arrival);
          const diffMin = Math.floor((arr - now) / 60000);
          let timeDisplay = '';
          let rowClass = 'incoming-row';
          if (diffMin > 0) {
            timeDisplay = '⏳ بعد ' + diffMin + ' دقيقة';
          } else {
            const minSince = Math.abs(diffMin);
            timeDisplay = '⚠️ <span class="time-arrived">وصلت منذ ' + minSince + ' دقيقة</span>';
            rowClass = 'arrived-row';
          }
          const driverName = t.driver_name || getDriverFromFleet(t.truck_number) || '';
          const sug = suggestOrderForTruck(t, undOrders, yStats);
          let sugText = '<span class="no-suggestion">لا يوجد طلب مناسب</span>';
          if (sug && sug.id) {
            sugText = sug.factory + ' - بحص ' + sug.material + ' (' + formatDistance(getDistance(sug.factory)) + ')';
            incHtml += '<tr class="' + rowClass + '" data-truck-id="' + t.id + '">' +
              '<td><strong>' + formatTruckNumber(t.truck_number) + '</strong></td>' +
              '<td>' + driverName + '</td>' +
              '<td>' + timeDisplay + '</td>' +
              '<td>' + sugText + '</td>' +
              '<td class="suggestion-buttons">' +
                '<button class="approve-btn" data-action="approve" data-truck="' + t.id + '" data-order="' + sug.id + '" data-truck-number="' + t.truck_number + '" data-driver="' + driverName + '" data-factory="' + sug.factory + '" data-material="' + sug.material + '">✅</button>' +
                '<button class="reject-btn" data-action="reject" data-truck="' + t.id + '">❌</button>' +
              '</td></tr>';
          } else {
            incHtml += '<tr class="' + rowClass + '" data-truck-id="' + t.id + '">' +
              '<td><strong>' + formatTruckNumber(t.truck_number) + '</strong></td>' +
              '<td>' + driverName + '</td>' +
              '<td>' + timeDisplay + '</td>' +
              '<td>' + sugText + '</td>' +
              '<td></td></tr>';
          }
        });
      }
      document.getElementById('incomingBody').innerHTML = incHtml;

      // التوزيعات
      let distHtml = '';
      if (!distributed.length) {
        distHtml = '<tr><td colspan="7">لا توجد توزيعات اليوم</td></tr>';
      } else {
        distributed.forEach(d => {
          const dist = getDistance(d.factory);
          distHtml += '<tr class="distributed-row" data-order-id="' + d.orderId + '">' +
            '<td><strong>' + formatTruckNumber(d.truck ? d.truck.number : '') + '</strong></td>' +
            '<td>' + (d.truck ? d.truck.driver : '?') + '</td>' +
            '<td>' + d.factory + '</td>' +
            '<td>بحص ' + d.material + '</td>' +
            '<td>' + formatDistance(dist) + '</td>' +
            '<td>رود ' + (d.road || 1) + '</td>' +
            '<td><button class="cancel-btn" data-action="cancel" data-order="' + d.orderId + '">🗑️</button></td>' +
            '</tr>';
        });
      }
      document.getElementById('distributedBody').innerHTML = distHtml;

      // الطلبات غير الموزعة
      let ordHtml = '';
      if (!undOrders.length) {
        ordHtml = '<tr><td colspan="6">🎉 جميع الطلبات موزعة بنجاح!</td></tr>';
      } else {
        undOrders.forEach((o, i) => {
          const dist = getDistance(o.factory);
          ordHtml += '<tr>' +
            '<td>' + (i+1) + '</td>' +
            '<td>' + o.factory + '</td>' +
            '<td>بحص ' + o.material + '</td>' +
            '<td>' + formatDistance(dist) + '</td>' +
            '<td>' + (o.time || '-') + '</td>' +
            '<td><button class="btn soft btn-sm" data-action="manual" data-order="' + o.id + '">🖐️ توزيع يدوي</button></td>' +
            '</tr>';
        });
      }
      document.getElementById('ordersBody').innerHTML = ordHtml;
    }

    // معالج الأحداث الرئيسي
    document.body.addEventListener('click', async function(e) {
      const target = e.target.closest('button');
      if (!target) return;
      
      if (target.dataset.action === 'approve') {
        const truckId = parseInt(target.dataset.truck, 10);
        const orderId = parseInt(target.dataset.order, 10);
        if (isNaN(truckId) || isNaN(orderId)) {
          alert('خطأ في قراءة معرف السيارة أو الطلب.');
          return;
        }
        target.disabled = true;
        await approveDistribution(truckId, orderId, target);
      }
      else if (target.dataset.action === 'reject') {
        const truckId = parseInt(target.dataset.truck, 10);
        if (isNaN(truckId)) return;
        openRejectModal(truckId);
      }
      else if (target.dataset.action === 'cancel') {
        const orderId = parseInt(target.dataset.order, 10);
        if (isNaN(orderId)) return;
        openCancelModal(orderId);
      }
      else if (target.dataset.action === 'manual') {
        const orderId = parseInt(target.dataset.order, 10);
        if (isNaN(orderId)) return;
        await openManualDistModal(orderId);
      }
    });

    async function approveDistribution(truckId, orderId, btn) {
      const truckNumber = btn.dataset.truckNumber || '';
      const driverName = btn.dataset.driver || '';
      const factory = btn.dataset.factory || '';
      const material = btn.dataset.material || '';

      if (!truckNumber || !factory) {
        alert('بيانات غير مكتملة في الزر.');
        btn.disabled = false;
        return;
      }

      try {
        await apiCall('/incoming-trucks/assign', 'POST', { truckId: truckId });
        
        incomingTrucksAll = incomingTrucksAll.filter(t => t.id != truckId);
        
        todayDistribution.push({
          orderId: orderId,
          truck: { number: truckNumber, driver: driverName },
          factory: factory,
          material: material,
          road: 1,
          distributedAt: new Date().toISOString()
        });
        
        renderCurrentTab();
        await saveToDatabase();
        showNotification(`✅ تم توزيع الطلب على السيارة ${formatTruckNumber(truckNumber)}`, 'success');
        
        setTimeout(loadAllData, 1000);
      } catch(e) {
        showNotification('❌ تعذر التوزيع: ' + e.message, 'error');
        await loadAllData();
      } finally {
        if (btn && document.body.contains(btn)) btn.disabled = false;
      }
    }

    function openRejectModal(truckId) {
      rejectTruckId = truckId;
      document.getElementById('rejectReason').value = '';
      document.getElementById('rejectReasonModal').classList.add('active');
    }
    
    function closeRejectModal() {
      document.getElementById('rejectReasonModal').classList.remove('active');
      rejectTruckId = null;
    }

    document.getElementById('submitRejectBtn').onclick = async function() {
      const reason = document.getElementById('rejectReason').value.trim();
      if (!reason) return alert('الرجاء كتابة سبب الرفض');
      if (!rejectTruckId) return;
      try {
        await apiCall('/incoming-trucks/ignore-suggestion', 'POST', { truckId: rejectTruckId, reason: reason });
        incomingTrucksAll = incomingTrucksAll.filter(t => t.id != rejectTruckId);
        renderCurrentTab();
        await loadAllData();
        showNotification('✅ تم تسجيل رفض التوزيع', 'success');
      } catch(e) { showNotification('❌ فشل: ' + e.message, 'error'); }
      finally { closeRejectModal(); }
    };
    document.getElementById('cancelRejectBtn').onclick = closeRejectModal;

    function openCancelModal(orderId) {
      cancelOrderId = orderId;
      document.getElementById('cancelReason').value = '';
      document.getElementById('cancelDistModal').classList.add('active');
    }
    
    function closeCancelModal() {
      document.getElementById('cancelDistModal').classList.remove('active');
      cancelOrderId = null;
    }
    
    document.getElementById('submitCancelBtn').onclick = async function() {
      const reason = document.getElementById('cancelReason').value.trim();
      if (!reason) return alert('الرجاء كتابة سبب الإلغاء');
      if (!cancelOrderId) return;
      try {
        todayDistribution = todayDistribution.filter(d => d.orderId != cancelOrderId);
        renderCurrentTab();
        await saveToDatabase();
        await loadAllData();
        showNotification('✅ تم إلغاء التوزيع', 'success');
      } catch(e) { showNotification('❌ فشل الإلغاء: ' + e.message, 'error'); }
      finally { closeCancelModal(); }
    };
    document.getElementById('cancelCancelBtn').onclick = closeCancelModal;

    async function openManualDistModal(orderId) {
      manualOrder = todayOrders.find(o => o.id == orderId);
      if (!manualOrder) return;
      
      await loadIncomingTrucks();
      
      const availableTrucks = incomingTrucksAll.filter(t => !t.assigned);
      if (!availableTrucks.length) {
        showNotification('❌ لا توجد سيارات قادمة متاحة للتوزيع حالياً', 'error');
        return;
      }
      
      const yStats = driverStatsFromDist(yesterdayDistribution);
      let bestTruck = null, bestScore = -Infinity;
      availableTrucks.forEach(t => {
        const y = yStats[t.truck_number] || {};
        const lastDist = y.lastDist || 0;
        const orderDist = getDistance(manualOrder.factory);
        if (orderDist === null) return;
        let score = 0;
        if (lastDist > 300 && orderDist < 300) score += 50;
        else if (lastDist < 200 && orderDist > 300) score += 50;
        score += (10 - Math.min(y.trips || 0, 10)) * 5;
        if (score > bestScore) { bestScore = score; bestTruck = t; }
      });
      
      const adviceText = bestTruck 
        ? '💡 النصيحة: توزيع الطلب على السيارة <strong>' + formatTruckNumber(bestTruck.truck_number) + '</strong> - ' + (bestTruck.driver_name || getDriverFromFleet(bestTruck.truck_number) || '')
        : '⚠️ لا توجد نصيحة واضحة، اختر يدوياً';
      document.getElementById('manualAdvice').innerHTML = adviceText;
      
      const select = document.getElementById('manualTruckSelect');
      select.innerHTML = '';
      availableTrucks.forEach(t => {
        const opt = document.createElement('option');
        opt.value = t.id;
        opt.textContent = formatTruckNumber(t.truck_number) + ' - ' + (t.driver_name || getDriverFromFleet(t.truck_number) || '');
        select.appendChild(opt);
      });
      
      document.getElementById('manualChoiceSection').style.display = 'block';
      document.getElementById('manualCustomSection').style.display = 'none';
      document.getElementById('manualDistModal').classList.add('active');
      window._bestTruckForManual = bestTruck;
    }

    function closeManualModal() {
      document.getElementById('manualDistModal').classList.remove('active');
      manualOrder = null;
    }

    document.getElementById('acceptManualAdvice').onclick = async function() {
      if (!window._bestTruckForManual) { showNotification('❌ لا توجد نصيحة متاحة', 'error'); return; }
      const best = window._bestTruckForManual;
      
      try {
        await apiCall('/incoming-trucks/assign', 'POST', { truckId: best.id });
        incomingTrucksAll = incomingTrucksAll.filter(t => t.id != best.id);
        todayDistribution.push({
          orderId: manualOrder.id,
          truck: { number: best.truck_number, driver: best.driver_name || getDriverFromFleet(best.truck_number) || '' },
          factory: manualOrder.factory,
          material: manualOrder.material,
          road: 1,
          distributedAt: new Date().toISOString()
        });
        renderCurrentTab();
        await saveToDatabase();
        setTimeout(loadAllData, 1000);
        closeManualModal();
        showNotification(`✅ تم توزيع الطلب على السيارة ${formatTruckNumber(best.truck_number)}`, 'success');
      } catch(e) { showNotification('❌ فشل التوزيع: ' + e.message, 'error'); }
    };
    
    document.getElementById('rejectManualAdvice').onclick = function() {
      document.getElementById('manualChoiceSection').style.display = 'none';
      document.getElementById('manualCustomSection').style.display = 'block';
      document.getElementById('manualCustomReason').value = '';
    };
    
    document.getElementById('confirmManualCustom').onclick = async function() {
      const truckId = document.getElementById('manualTruckSelect').value;
      const reason = document.getElementById('manualCustomReason').value.trim();
      if (!reason) return showNotification('❌ يجب ذكر سبب اختيار سيارة أخرى', 'error');
      const truck = incomingTrucksAll.find(t => t.id == truckId);
      if (!truck) return showNotification('❌ السيارة غير موجودة', 'error');
      
      try {
        await apiCall('/incoming-trucks/assign', 'POST', { truckId: truck.id });
        incomingTrucksAll = incomingTrucksAll.filter(t => t.id != truck.id);
        todayDistribution.push({
          orderId: manualOrder.id,
          truck: { number: truck.truck_number, driver: truck.driver_name || getDriverFromFleet(truck.truck_number) || '' },
          factory: manualOrder.factory,
          material: manualOrder.material,
          road: 1,
          manualOverride: true,
          overrideReason: reason,
          distributedAt: new Date().toISOString()
        });
        renderCurrentTab();
        await saveToDatabase();
        setTimeout(loadAllData, 1000);
        closeManualModal();
        showNotification(`✅ تم توزيع الطلب على السيارة ${formatTruckNumber(truck.truck_number)}`, 'success');
      } catch(e) { showNotification('❌ فشل التوزيع: ' + e.message, 'error'); }
    };
    
    document.getElementById('closeManualModalBtn').onclick = closeManualModal;

    async function loadIncomingTrucks() {
      try {
        const rawIncoming = await fetch('/api/incoming-trucks', { credentials: 'include' }).then(r => r.json());
        allIncomingRaw = rawIncoming;
        incomingTrucksAll = filterByTimeWindow(rawIncoming, currentDate);
      } catch(e) {
        console.error('فشل تحميل السيارات القادمة:', e.message);
      }
    }

    async function loadAllData() {
      if (consecutiveFailures >= 3) return;
      currentDate = document.getElementById('orderDate').value;
      const yesterday = getYesterdayStr();
      try {
        const [dayRes, yesterdayRes] = await Promise.all([
          apiCall('/day/' + currentDate),
          apiCall('/day/' + yesterday).catch(() => ({ distribution: [] }))
        ]);
        todayOrders = dayRes.orders || [];
        todayDistribution = dayRes.distribution || [];
        yesterdayDistribution = yesterdayRes.distribution || [];
        await loadIncomingTrucks();
        renderCurrentTab();
      } catch(e) {
        console.error('فشل تحميل البيانات:', e.message);
        showOfflineAlert();
      }
    }

    // زر حفظ البيانات
    document.getElementById('saveToDbBtn').onclick = async function() {
      document.getElementById('confirmDate').innerText = currentDate;
      document.getElementById('saveConfirmModal').classList.add('active');
    };
    
    document.getElementById('confirmSaveBtn').onclick = async function() {
      document.getElementById('saveConfirmModal').classList.remove('active');
      await saveToDatabase();
    };
    
    document.getElementById('cancelSaveBtn').onclick = function() {
      document.getElementById('saveConfirmModal').classList.remove('active');
    };

    // تبويبات
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        this.classList.add('active');
        const tab = this.getAttribute('data-tab');
        document.getElementById('panel-incoming').style.display = tab === 'incoming' ? '' : 'none';
        document.getElementById('panel-distributed').style.display = tab === 'distributed' ? '' : 'none';
        document.getElementById('panel-orders').style.display = tab === 'orders' ? '' : 'none';
        currentTab = tab;
        renderCurrentTab();
      });
    });

    // مزامنة Gmail
    document.getElementById('syncGmailBtn').onclick = async function() {
      const btn = this;
      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري...';
      try {
        const res = await fetch('/api/gmail/sync', { method: 'POST', credentials: 'include' });
        const data = await res.json();
        showNotification(`✅ تم المزامنة: أُضيف ${data.added || 0} سيارة جديدة`, 'success');
        await loadAllData();
      } catch(e) { showNotification('❌ فشل المزامنة: ' + e.message, 'error'); }
      finally { btn.disabled = false; btn.innerHTML = '<i class="fas fa-envelope"></i> مزامنة Gmail'; }
    };

    // تهيئة الصفحة
    document.getElementById('orderDate').value = new Date().toISOString().slice(0,10);
    (async function init() {
      await loadFleetFromAPI();
      await loadFactoryDistances();
      document.getElementById('orderDate').addEventListener('change', loadAllData);
      await loadAllData();
      autoRefreshInterval = setInterval(() => {
        if (consecutiveFailures < 3) loadAllData();
      }, 30000);
    })();
  })();
</script>
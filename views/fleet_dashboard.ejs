                7928: "امير", 7929: "طاهر محمود", 7930: "نارندر", 7974: "شريف",
                7980: "شعيب", 9103: "ساكب", 9492: "عدنان", 9493: "عامر",
                9495: "ميزان", 9496: "غفور احمد"
            };

            // ═══════════════════════════════════════════
            // متغيرات الأسطول
            // ═══════════════════════════════════════════
            let fuelByCode = {};
            let driverByCode = {};
            let plateByCode = {};
            let codeList = [];
            let driversList = [];

            // ═══════════════════════════════════════════
            // متغيرات التوزيع
            // ═══════════════════════════════════════════
            let orders = []; // { id, code, driver, status }
            let nextOrderId = 1;

            // ═══════════════════════════════════════════
            // دوال التحميل والحفظ (محلية)
            // ═══════════════════════════════════════════
            function loadFleetData() {
                const savedCodes = localStorage.getItem('fleet_code_list');
                if (savedCodes && JSON.parse(savedCodes).length) {
                    codeList = JSON.parse(savedCodes);
                } else {
                    codeList = fullTrucksData.map(t => t.code);
                }

                const savedPlates = localStorage.getItem('fleet_plate_by_code');
                plateByCode = savedPlates ? JSON.parse(savedPlates) : {};
                fullTrucksData.forEach(t => { if (!plateByCode[t.code]) plateByCode[t.code] = t.plate; });

                const savedFuel = localStorage.getItem('fleet_fuel_by_code');
                fuelByCode = savedFuel ? JSON.parse(savedFuel) : {};
                fullTrucksData.forEach(t => { if (fuelByCode[t.code] === undefined) fuelByCode[t.code] = t.defaultFuel; });

                const savedDrivers = localStorage.getItem('fleet_driver_by_code');
                if (savedDrivers) {
                    driverByCode = JSON.parse(savedDrivers);
                } else {
                    driverByCode = {};
                    codeList.forEach(code => { driverByCode[code] = DEFAULT_DRIVER_MAP[code] || "غير معين"; });
                }

                const savedDriversList = localStorage.getItem('fleet_drivers_list');
                if (savedDriversList && JSON.parse(savedDriversList).length) {
                    driversList = JSON.parse(savedDriversList);
                } else {
                    driversList = [...new Set(Object.values(driverByCode).filter(d => d !== "غير معين"))].sort();
                }

                // مزامنة السائقين من التعيينات
                const existing = new Set(driversList);
                Object.values(driverByCode).forEach(d => { if (d !== "غير معين" && !existing.has(d)) driversList.push(d); });
                driversList.sort();
            }

            function loadOrders() {
                const saved = localStorage.getItem('distribution_orders');
                orders = saved ? JSON.parse(saved) : [];
                if (orders.length > 0) {
                    nextOrderId = Math.max(...orders.map(o => o.id)) + 1;
                } else {
                    nextOrderId = 1;
                }
            }

            function saveFleetData() {
                localStorage.setItem('fleet_code_list', JSON.stringify(codeList));
                localStorage.setItem('fleet_plate_by_code', JSON.stringify(plateByCode));
                localStorage.setItem('fleet_fuel_by_code', JSON.stringify(fuelByCode));
                localStorage.setItem('fleet_driver_by_code', JSON.stringify(driverByCode));
                localStorage.setItem('fleet_drivers_list', JSON.stringify(driversList));
            }
            function saveOrders() {
                localStorage.setItem('distribution_orders', JSON.stringify(orders));
            }

            function getTruckByCode(code) { return fullTrucksData.find(t => t.code === code) || null; }
            function getDriverByCode(code) { return driverByCode[code] || "غير معين"; }
            function getPlateByCode(code) { return plateByCode[code] || `${code} ---`; }
            function getFuelByCode(code) { return fuelByCode[code] !== undefined ? fuelByCode[code] : (getTruckByCode(code)?.defaultFuel || 3.2); }

            // ═══════════════════════════════════════════
            // دوال العرض – الأسطول
            // ═══════════════════════════════════════════
            function renderCarsTable() {
                const tbody = document.getElementById('carsBody');
                if (!tbody) return;
                let html = '';
                codeList.forEach((code, idx) => {
                    const truck = getTruckByCode(code);
                    const brand = truck ? truck.brand : '---';
                    const year = truck ? truck.year : '---';
                    const plate = getPlateByCode(code);
                    const fuel = getFuelByCode(code);
                    const driver = getDriverByCode(code);
                    html += `<tr data-code="${code}">
                <td>${idx+1}</td>
                <td><span class="code-badge">${code}</span></td>
                <td>${escapeHtml(String(brand))}</td>
                <td>${year}</td>
                <td><span class="plate-badge">${escapeHtml(plate)}</span></td>
                <td><input type="number" step="0.1" class="fuel-input" data-code="${code}" value="${fuel}"></td>
                <td>
                  <select class="driver-select-inline" data-code="${code}">
                    <option value="غير معين" ${driver==='غير معين'?'selected':''}>غير معين</option>
                    ${driversList.map(d => `<option value="${escapeHtml(d)}" ${d===driver?'selected':''}>${escapeHtml(d)}</option>`).join('')}
                  </select>
                </td>
                <td><button class="icon-btn edit-car-btn" data-code="${code}" title="تعديل"><i class="fas fa-edit"></i></button></td>
              </tr>`;
                });
                tbody.innerHTML = html;
                bindCarsEvents();
            }
            function bindCarsEvents() {
                document.querySelectorAll('#carsBody .fuel-input').forEach(inp => {
                    inp.addEventListener('change', () => {
                        const code = parseInt(inp.dataset.code);
                        const val = parseFloat(inp.value);
                        if (!isNaN(val) && val > 0) { fuelByCode[code] = val;
                            saveFleetData();
                            showToast(`تم تحديث كفاءة الكود ${code}`, 'success'); }
                    });
                });
                document.querySelectorAll('#carsBody .driver-select-inline').forEach(sel => {
                    sel.addEventListener('change', () => {
                        const code = parseInt(sel.dataset.code);
                        const newDriver = sel.value;
                        driverByCode[code] = newDriver;
                        saveFleetData();
                        if (!driversList.includes(newDriver) && newDriver !== "غير معين") {
                            driversList.push(newDriver);
                            driversList.sort();
                            localStorage.setItem('fleet_drivers_list', JSON.stringify(driversList));
                        }
                        renderAllFleet();
                        renderDistributionDriverSelect();
                        showToast(`تم تعيين ${newDriver} للكود ${code}`, 'success');
                    });
                });
                document.querySelectorAll('#carsBody .edit-car-btn').forEach(btn => {
                    btn.addEventListener('click', () => {
                        const code = parseInt(btn.dataset.code);
                        const truck = getTruckByCode(code);
                        const newBrand = prompt('الماركة:', truck ? truck.brand : '');
                        const newYear = prompt('سنة الإنتاج:', truck ? truck.year : '');
                        if (newBrand && newYear) {
                            if (truck) { truck.brand = newBrand;
                                truck.year = parseInt(newYear); }
                            renderCarsTable();
                            showToast(`تم تعديل بيانات الكود ${code}`, 'success');
                        }
                    });
                });
            }

            function renderCodesTable() {
                const tbody = document.getElementById('codesBody');
                if (!tbody) return;
                let html = '';
                codeList.forEach((code, idx) => {
                    const plate = getPlateByCode(code);
                    html += `<tr><td>${idx+1}</td><td><span class="code-badge">${code}</span></td><td>${escapeHtml(plate)}</td>
                <td><button class="icon-btn delete-code-btn" data-code="${code}"><i class="fas fa-trash-alt" style="color:#ef4444;"></i></button></td></tr>`;
                });
                tbody.innerHTML = html;
                tbody.querySelectorAll('.delete-code-btn').forEach(btn => {
                    btn.addEventListener('click', () => deleteCode(parseInt(btn.dataset.code)));
                });
            }

            function renderPlatesTable() {
                const tbody = document.getElementById('platesBody');
                if (!tbody) return;
                let html = '';
                codeList.forEach((code, idx) => {
                    const plate = getPlateByCode(code);
                    html += `<tr data-code="${code}">
                <td>${idx+1}</td>
                <td><span class="plate-badge plate-text">${escapeHtml(plate)}</span><input type="text" class="edit-plate-input" value="${escapeHtml(plate)}" style="display:none;width:140px;"></td>
                <td><span class="code-badge">${code}</span></td>
                <td>
                  <button class="icon-btn edit-plate-btn" data-code="${code}"><i class="fas fa-edit"></i></button>
                  <button class="icon-btn save-plate-btn" data-code="${code}" style="display:none;"><i class="fas fa-save" style="color:#10b981;"></i></button>
                  <button class="icon-btn delete-plate-btn" data-code="${code}"><i class="fas fa-trash-alt" style="color:#ef4444;"></i></button>
                </td>
              </tr>`;
                });
                tbody.innerHTML = html;
                bindPlatesEvents();
            }
            function bindPlatesEvents() {
                document.querySelectorAll('#platesBody .edit-plate-btn').forEach(btn => {
                    btn.addEventListener('click', () => {
                        const code = parseInt(btn.dataset.code);
                        const row = btn.closest('tr');
                        row.querySelector('.plate-text').style.display = 'none';
                        row.querySelector('.edit-plate-input').style.display = 'inline-block';
                        btn.style.display = 'none';
                        row.querySelector('.save-plate-btn').style.display = 'inline-block';
                    });
                });
                document.querySelectorAll('#platesBody .save-plate-btn').forEach(btn => {
                    btn.addEventListener('click', () => {
                        const code = parseInt(btn.dataset.code);
                        const row = btn.closest('tr');
                        const newPlate = row.querySelector('.edit-plate-input').value.trim();
                        if (newPlate) updatePlate(code, newPlate);
                    });
                });
                document.querySelectorAll('#platesBody .delete-plate-btn').forEach(btn => {
                    btn.addEventListener('click', () => {
                        const code = parseInt(btn.dataset.code);
                        if (confirm(`حذف لوحة الكود ${code}؟`)) deletePlate(code);
                    });
                });
            }

            function renderAssignmentsTable() {
                const tbody = document.getElementById('assignmentsBody');
                if (!tbody) return;
                let html = '';
                codeList.forEach((code, idx) => {
                    const plate = getPlateByCode(code);
                    const driver = getDriverByCode(code);
                    html += `<tr data-code="${code}">
                <td>${idx+1}</td><td><span class="code-badge">${code}</span></td><td><span class="plate-badge">${escapeHtml(plate)}</span></td>
                <td>${escapeHtml(driver)}</td>
                <td><select class="assign-driver-select" data-code="${code}">
                  <option value="غير معين" ${driver==='غير معين'?'selected':''}>غير معين</option>
                  ${driversList.map(d => `<option value="${escapeHtml(d)}" ${d===driver?'selected':''}>${escapeHtml(d)}</option>`).join('')}
                </select></td>
                <td><button class="btn btn-sm btn-primary save-assign-btn" data-code="${code}">💾 حفظ</button></td>
              </tr>`;
                });
                tbody.innerHTML = html;
                tbody.querySelectorAll('.save-assign-btn').forEach(btn => {
                    btn.addEventListener('click', () => {
                        const code = parseInt(btn.dataset.code);
                        const newDriver = document.querySelector(`.assign-driver-select[data-code="${code}"]`)?.value;
                        if (newDriver !== undefined) {
                            driverByCode[code] = newDriver;
                            saveFleetData();
                            if (!driversList.includes(newDriver) && newDriver !== "غير معين") {
                                driversList.push(newDriver);
                                driversList.sort();
                                localStorage.setItem('fleet_drivers_list', JSON.stringify(driversList));
                            }
                            renderAllFleet();
                            renderDistributionDriverSelect();
                            showToast(`تم تعيين ${newDriver} للكود ${code}`, 'success');
                        }
                    });
                });
            }

            function renderDriversTable() {
                const tbody = document.getElementById('driversListBody');
                if (!tbody) return;
                let html = '';
                driversList.forEach((driver, idx) => {
                    html += `<tr>
                <td>${idx+1}</td>
                <td><span class="driver-name-text">${escapeHtml(driver)}</span><input type="text" class="edit-driver-input" value="${escapeHtml(driver)}" style="display:none;width:150px;"></td>
                <td>
                  <button class="icon-btn edit-driver" data-driver="${escapeHtml(driver)}"><i class="fas fa-edit"></i></button>
                  <button class="icon-btn save-driver" data-driver="${escapeHtml(driver)}" style="display:none;"><i class="fas fa-save" style="color:#10b981;"></i></button>
                  <button class="icon-btn delete-driver" data-driver="${escapeHtml(driver)}"><i class="fas fa-trash-alt" style="color:#ef4444;"></i></button>
                </td>
              </tr>`;
                });
                tbody.innerHTML = html;
                bindDriversEvents();
            }
            function bindDriversEvents() {
                document.querySelectorAll('#driversListBody .edit-driver').forEach(btn => {
                    btn.addEventListener('click', () => {
                        const driver = btn.dataset.driver;
                        const row = btn.closest('tr');
                        row.querySelector('.driver-name-text').style.display = 'none';
                        row.querySelector('.edit-driver-input').style.display = 'inline-block';
                        btn.style.display = 'none';
                        row.querySelector('.save-driver').style.display = 'inline-block';
                    });
                });
                document.querySelectorAll('#driversListBody .save-driver').forEach(btn => {
                    btn.addEventListener('click', () => {
                        const oldDriver = btn.dataset.driver;
                        const row = btn.closest('tr');
                        const newDriver = row.querySelector('.edit-driver-input').value.trim();
                        if (newDriver && newDriver !== oldDriver) updateDriver(oldDriver, newDriver);
                        else if (!newDriver) showToast('الاسم لا يمكن أن يكون فارغاً', 'error');
                    });
                });
                document.querySelectorAll('#driversListBody .delete-driver').forEach(btn => {
                    btn.addEventListener('click', () => {
                        const driver = btn.dataset.driver;
                        if (confirm(`حذف السائق ${driver}؟`)) deleteDriver(driver);
                    });
                });
            }

            function renderAllFleet() {
                renderCarsTable();
                renderCodesTable();
                renderPlatesTable();
                renderAssignmentsTable();
                renderDriversTable();
            }

            // ═══════════════════════════════════════════
            // دوال إدارة الأسطول (التعديلات)
            // ═══════════════════════════════════════════
            function addCode(code) {
                if (isNaN(code) || codeList.includes(code)) return showToast('الكود موجود أو غير صحيح', 'error');
                codeList.push(code);
                codeList.sort((a,b)=>a-b);
                if (!fuelByCode[code]) fuelByCode[code] = 3.2;
                if (!driverByCode[code]) driverByCode[code] = "غير معين";
                if (!plateByCode[code]) plateByCode[code] = `${code} ---`;
                saveFleetData();
                renderAllFleet();
                renderDistributionDriverSelect();
                showToast(`تمت إضافة الكود ${code}`, 'success');
            }
            function deleteCode(code) {
                if (!codeList.includes(code)) return;
                if (!confirm(`حذف الكود ${code} وجميع بياناته؟`)) return;
                codeList = codeList.filter(c => c !== code);
                delete fuelByCode[code];
                delete driverByCode[code];
                delete plateByCode[code];
                saveFleetData();
                renderAllFleet();
                renderDistributionDriverSelect();
                showToast(`تم حذف الكود ${code}`, 'success');
            }
            function updatePlate(code, newPlate) {
                plateByCode[code] = newPlate.trim();
                saveFleetData();
                renderAllFleet();
            }
            function deletePlate(code) {
                plateByCode[code] = `${code} ---`;
                saveFleetData();
                renderAllFleet();
            }
            function updateDriver(oldName, newName) {
                const idx = driversList.indexOf(oldName);
                if (idx !== -1) {
                    driversList[idx] = newName;
                    driversList.sort();
                    Object.keys(driverByCode).forEach(code => { if (driverByCode[code] === oldName) driverByCode[code] = newName; });
                    saveFleetData();
                    renderAllFleet();
                    renderDistributionDriverSelect();
                    showToast(`تم تعديل السائق إلى ${newName}`, 'success');
                }
            }
            function deleteDriver(driverName) {
                if (driverName === "غير معين") return showToast('لا يمكن حذف السائق الافتراضي', 'error');
                const idx = driversList.indexOf(driverName);
                if (idx !== -1) {
                    driversList.splice(idx, 1);
                    Object.keys(driverByCode).forEach(code => { if (driverByCode[code] === driverName) driverByCode[code] = "غير معين"; });
                    saveFleetData();
                    renderAllFleet();
                    renderDistributionDriverSelect();
                    showToast(`تم حذف السائق ${driverName}`, 'success');
                }
            }

            // ═══════════════════════════════════════════
            // دوال التوزيع
            // ═══════════════════════════════════════════
            function renderOrdersTable() {
                const tbody = document.getElementById('ordersBody');
                if (!tbody) return;
                let html = '';
                orders.forEach((order, idx) => {
                    const statusText = order.status === 'pending' ? 'قيد الانتظار' : 'تم التوزيع';
                    html += `<tr>
                <td>${idx+1}</td>
                <td>${order.id}</td>
                <td><span class="code-badge">${order.code}</span></td>
                <td>${escapeHtml(order.driver)}</td>
                <td>${statusText}</td>
                <td>${order.status === 'pending' ? `<button class="btn btn-sm btn-success approve-order" data-id="${order.id}">✔️ توزيع</button>` : '✅'}</td>
              </tr>`;
                });
                tbody.innerHTML = html;
                tbody.querySelectorAll('.approve-order').forEach(btn => {
                    btn.addEventListener('click', () => approveOrder(parseInt(btn.dataset.id)));
                });
            }

            function approveOrder(orderId) {
                const order = orders.find(o => o.id === orderId);
                if (!order || order.status !== 'pending') return;
                // التحقق النهائي من وجود الكود (يجب أن يكون موجوداً)
                if (!codeList.includes(order.code)) {
                    showToast(`الكود ${order.code} لم يعد موجوداً في الأسطول!`, 'error');
                    return;
                }
                order.status = 'approved';
                saveOrders();
                renderOrdersTable();
                showToast(`تم توزيع الأمر ${orderId} على الكود ${order.code}`, 'success');
            }

            function addOrderFromInput() {
                const codeInput = document.getElementById('distCodeInput');
                const driverSelect = document.getElementById('distDriverSelect');
                let selectedCode = null;
                let selectedDriver = "";

                if (codeInput.value.trim() !== '') {
                    const numericCode = parseInt(codeInput.value);
                    if (isNaN(numericCode) || !codeList.includes(numericCode)) {
                        showToast('الكود غير موجود في الأسطول', 'error');
                        return;
                    }
                    selectedCode = numericCode;
                    selectedDriver = getDriverByCode(selectedCode);
                } else if (driverSelect.value !== '') {
                    selectedDriver = driverSelect.value;
                    // البحث عن أول كود لهذا السائق
                    for (let [code, driver] of Object.entries(driverByCode)) {
                        if (driver === selectedDriver) {
                            selectedCode = parseInt(code);
                            break;
                        }
                    }
                    if (!selectedCode) {
                        showToast('لا يوجد كود مرتبط بهذا السائق', 'error');
                        return;
                    }
                } else {
                    showToast('يجب إدخال كود أو اختيار سائق', 'error');
                    return;
                }

                // إنشاء الأمر
                const newOrder = {
                    id: nextOrderId++,
                    code: selectedCode,
                    driver: selectedDriver,
                    status: 'pending'
                };
                orders.push(newOrder);
                saveOrders();
                renderOrdersTable();
                document.getElementById('distCodeInput').value = '';
                document.getElementById('distDriverSelect').value = '';
                document.getElementById('orderIdInput').value = nextOrderId; // توقع الرقم التالي
                showToast(`تمت إضافة الأمر ${newOrder.id}`, 'success');
            }

            function renderDistributionDriverSelect() {
                const select = document.getElementById('distDriverSelect');
                if (!select) return;
                select.innerHTML = '<option value="">-- اختر سائق --</option>';
                driversList.forEach(d => {
                    select.innerHTML += `<option value="${escapeHtml(d)}">${escapeHtml(d)}</option>`;
                });
            }

            // ═══════════════════════════════════════════
            // دوال عامة
            // ═══════════════════════════════════════════
            function escapeHtml(str) { return String(str).replace(/[&<>]/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;'})[m]); }
            function showToast(msg, type='success') {
                const container = document.getElementById('toastContainer');
                const toast = document.createElement('div');
                toast.className = `toast ${type}`;
                toast.innerText = msg;
                container.appendChild(toast);
                setTimeout(() => { toast.style.opacity='0';
                    toast.style.transition='0.3s';
                    setTimeout(() => toast.remove(), 300); }, 3000);
            }

            // ═══════════════════════════════════════════
            // التبويبات
            // ═══════════════════════════════════════════
            function initMainTabs() {
                document.querySelectorAll('.main-tab-btn').forEach(btn => {
                    btn.addEventListener('click', () => {
                        const main = btn.dataset.main;
                        document.querySelectorAll('.main-tab-btn').forEach(b => b.classList.remove('active'));
                        document.querySelectorAll('.main-content').forEach(c => c.classList.remove('active'));
                        btn.classList.add('active');
                        document.getElementById(`main-${main}`).classList.add('active');
                    });
                });
            }
            function initFleetTabs() {
                document.querySelectorAll('.fleet-tab-btn').forEach(btn => {
                    btn.addEventListener('click', () => {
                        const fleetTab = btn.dataset.fleet;
                        document.querySelectorAll('.fleet-tab-btn').forEach(b => b.classList.remove('active'));
                        document.querySelectorAll('.fleet-tab-content').forEach(c => c.classList.remove('active'));
                        btn.classList.add('active');
                        document.getElementById(`fleet-${fleetTab}`).classList.add('active');
                    });
                });
            }

            // ═══════════════════════════════════════════
            // التصدير
            // ═══════════════════════════════════════════
            async function exportFleetExcel() {
                try {
                    const wb = new ExcelJS.Workbook();
                    const ws = wb.addWorksheet('الأسطول');
                    ws.columns = [
                        { header: '#', key: 'index', width: 8 },
                        { header: 'الكود', key: 'code', width: 12 },
                        { header: 'الماركة', key: 'brand', width: 15 },
                        { header: 'سنة الإنتاج', key: 'year', width: 12 },
                        { header: 'رقم اللوحة', key: 'plate', width: 18 },
                        { header: 'معدل الاستهلاك', key: 'fuel', width: 20 },
                        { header: 'السائق', key: 'driver', width: 20 }
                    ];
                    const rows = codeList.map((code, i) => {
                        const truck = getTruckByCode(code);
                        return {
                            index: i+1, code, brand: truck?.brand || '---', year: truck?.year || '---',
                            plate: getPlateByCode(code), fuel: getFuelByCode(code), driver: getDriverByCode(code)
                        };
                    });
                    ws.addRows(rows);
                    ws.getRow(1).eachCell(cell => { cell.font = { bold: true };
                        cell.fill = { type: 'pattern', pattern:'solid', fgColor:{ argb:'FFC5E0B4' } }; });
                    const buffer = await wb.xlsx.writeBuffer();
                    saveAs(new Blob([buffer]), `الاسطول_${new Date().toISOString().slice(0,10)}.xlsx`);
                    showToast('تم تصدير الأسطول', 'success');
                } catch(e) { showToast('خطأ في التصدير', 'error'); }
            }
            async function exportOrdersExcel() {
                try {
                    const wb = new ExcelJS.Workbook();
                    const ws = wb.addWorksheet('أوامر التوزيع');
                    ws.columns = [
                        { header: '#', key: 'index', width: 8 },
                        { header: 'رقم الأمر', key: 'id', width: 12 },
                        { header: 'كود السيارة', key: 'code', width: 12 },
                        { header: 'السائق', key: 'driver', width: 20 },
                        { header: 'الحالة', key: 'status', width: 15 }
                    ];
                    const rows = orders.map((o, i) => ({
                        index: i+1, id: o.id, code: o.code, driver: o.driver,
                        status: o.status === 'pending' ? 'قيد الانتظار' : 'تم التوزيع'
                    }));
                    ws.addRows(rows);
                    ws.getRow(1).eachCell(cell => { cell.font = { bold: true }; });
                    const buffer = await wb.xlsx.writeBuffer();
                    saveAs(new Blob([buffer]), `اوامر_التوزيع_${new Date().toISOString().slice(0,10)}.xlsx`);
                    showToast('تم تصدير أوامر التوزيع', 'success');
                } catch(e) { showToast('خطأ', 'error'); }
            }

            // ═══════════════════════════════════════════
            // بدء التشغيل
            // ═══════════════════════════════════════════
            loadFleetData();
            loadOrders();
            initMainTabs();
            initFleetTabs();
            renderAllFleet();
            renderOrdersTable();
            renderDistributionDriverSelect();
            document.getElementById('orderIdInput').value = nextOrderId;

            // ربط الأزرار
            document.getElementById('saveFuelBtn')?.addEventListener('click', ()=>{ saveFleetData();
                showToast('تم حفظ كفاءة الديزل', 'success'); });
            document.getElementById('saveAssignmentsBtn')?.addEventListener('click', ()=>{ saveFleetData();
                showToast('تم حفظ التعيينات', 'success'); });
            document.getElementById('saveDriversBtn')?.addEventListener('click', ()=>{ localStorage.setItem('fleet_drivers_list', JSON.stringify(driversList));
                showToast('تم حفظ قائمة السائقين', 'success'); });
            document.getElementById('saveCodesBtn')?.addEventListener('click', ()=>{ saveFleetData();
                showToast('تم حفظ الكودات', 'success'); });
            document.getElementById('savePlatesBtn')?.addEventListener('click', ()=>{ saveFleetData();
                showToast('تم حفظ اللوحات', 'success'); });
            document.getElementById('exportFleetBtn')?.addEventListener('click', exportFleetExcel);
            document.getElementById('exportDriversBtn')?.addEventListener('click', async ()=>{
                try { const wb = new ExcelJS.Workbook(); const ws = wb.addWorksheet('السائقين');
                    ws.columns = [{ header: '#', key: 'index', width: 8 }, { header: 'اسم السائق', key: 'name', width: 30 }];
                    ws.addRows(driversList.map((d,i)=>({ index:i+1, name:d })));
                    const buffer = await wb.xlsx.writeBuffer();
                    saveAs(new Blob([buffer]), `السائقين_${new Date().toISOString().slice(0,10)}.xlsx`);
                    showToast('تم تصدير السائقين', 'success'); } catch(e) { showToast('خطأ', 'error'); } });
            document.getElementById('addDriverBtn')?.addEventListener('click', ()=>{
                const name = document.getElementById('newDriverName')?.value.trim();
                if (name) { if (!driversList.includes(name)) { driversList.push(name);
                        driversList.sort();
                        localStorage.setItem('fleet_drivers_list', JSON.stringify(driversList));
                        renderAllFleet();
                        renderDistributionDriverSelect();
                        showToast(`تمت إضافة السائق ${name}`, 'success'); } else showToast('السائق موجود بالفعل', 'error'); }
                else showToast('يرجى إدخال اسم', 'error');
                document.getElementById('newDriverName').value = '';
            });
            document.getElementById('addCodeBtn')?.addEventListener('click', ()=>{
                const code = parseInt(document.getElementById('newCodeInput')?.value);
                if (code) addCode(code);
                else showToast('يرجى إدخال كود رقمي', 'error');
                document.getElementById('newCodeInput').value = '';
            });
            document.getElementById('addPlateBtn')?.addEventListener('click', ()=>{
                const plate = document.getElementById('newPlateInput')?.value.trim();
                const code = parseInt(document.getElementById('newPlateCodeInput')?.value);
                if (plate && code) {
                    if (!codeList.includes(code)) addCode(code);
                    updatePlate(code, plate);
                    document.getElementById('newPlateInput').value = '';
                    document.getElementById('newPlateCodeInput').value = '';
                } else showToast('يرجى إدخال اللوحة والكود', 'error');
            });
            document.getElementById('addOrderBtn')?.addEventListener('click', addOrderFromInput);
            document.getElementById('exportOrdersBtn')?.addEventListener('click', exportOrdersExcel);

            // API عام للتواصل
            window.fleetAPI = {
                getFuelByCode: (c) => getFuelByCode(parseInt(c)),
                getDriverByCode: (c) => getDriverByCode(parseInt(c)),
                getPlateByCode: (c) => getPlateByCode(parseInt(c)),
                getAllCodes: () => [...codeList],
                getAllDrivers: () => [...driversList],
                getAllTrucks: () => codeList.map(c => ({ code: c, brand: getTruckByCode(c)?.brand, plate: getPlateByCode(c), driver: getDriverByCode(c) })),
            };
        })();
    </script>
</body>
</html>
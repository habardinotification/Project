<!-- views/expenses.ejs - تقرير دخل السيارات ومصاريفها (مع دمج تقارير وتصدير كامل) -->
<style>
  /* جميع الأنماط السابقة كما هي - أدرجها كاملة للاختصار سأضع الأساسيات */
  .kpi-grid { display: flex; flex-wrap: wrap; gap: 1rem; margin-bottom: 1.5rem; }
  .kpi-card { background: var(--bg-card); border: 1px solid var(--border-color); border-radius: var(--radius-md); padding: 1rem; text-align: center; min-width: 160px; flex: 1; }
  .kpi-value { font-size: 1.5rem; font-weight: bold; color: var(--primary); }
  .table-responsive { overflow-x: auto; margin-top: 1rem; }
  table { width: 100%; border-collapse: collapse; min-width: 600px; }
  th, td { padding: 0.75rem; text-align: center; border-bottom: 1px solid var(--border-color); }
  th { background: var(--bg-sidebar); }
  .net-percent-red { color: var(--danger); font-weight: bold; }
  .net-percent-yellow { color: var(--warning); font-weight: bold; }
  .net-percent-green { color: var(--success); font-weight: bold; }
  .top-categories-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem; margin-top: 1.5rem; }
  .top-category-card { background: var(--bg-card); border: 1px solid var(--border-color); border-radius: var(--radius-lg); padding: 1rem; }
  .chart-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 1.5rem; margin-top: 1.5rem; }
  .chart-card { background: var(--bg-card); border: 1px solid var(--border-color); border-radius: var(--radius-lg); padding: 1rem; }
  canvas { max-height: 280px; width: 100%; }
  .reminder-box { background: var(--warning); padding: 0.75rem; border-radius: var(--radius-md); margin: 1rem 0; text-align: center; display: none; }
  .upload-card, .reports-panel { background: var(--bg-card); border: 1px solid var(--border-color); border-radius: var(--radius-lg); padding: 1rem; margin-bottom: 1.5rem; }
  .reports-list { display: flex; flex-wrap: wrap; gap: 1rem; max-height: 500px; overflow-y: auto; margin-top: 1rem; }
  .report-card { background: var(--bg-sidebar); border: 1px solid var(--border-color); border-radius: var(--radius-md); padding: 0.8rem; width: 240px; position: relative; }
  .report-card.selected { border-color: var(--primary); background: rgba(var(--primary-rgb), 0.1); }
  .report-checkbox { position: absolute; top: 8px; left: 8px; width: 18px; height: 18px; cursor: pointer; accent-color: var(--primary); }
  .report-name { font-weight: bold; display: block; margin-top: 20px; }
  .report-date { font-size: 0.7rem; color: var(--text-muted); }
  .report-actions { margin-top: 0.5rem; display: flex; gap: 0.5rem; justify-content: center; }
  .selection-bar { background: var(--bg-card); border: 1px solid var(--border-color); border-radius: var(--radius-md); padding: 0.5rem 1rem; margin-bottom: 1rem; display: flex; justify-content: space-between; align-items: center; }
  .selected-count { font-weight: bold; color: var(--primary); }
  .toast-container { position: fixed; top: 70px; left: 20px; z-index: 3000; }
  .toast { background: var(--bg-card); border-right: 4px solid var(--primary); padding: 0.6rem 1rem; margin-top: 0.5rem; border-radius: 0.8rem; }
  .spinner { width: 40px; height: 40px; border: 4px solid rgba(255,255,255,0.3); border-top-color: var(--primary); border-radius: 50%; animation: spin 0.6s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }
  #globalLoader { position: fixed; top:0; left:0; width:100%; height:100%; background: rgba(0,0,0,0.6); display: flex; align-items: center; justify-content: center; z-index: 9999; }
  @media (max-width: 768px) { .reports-list { justify-content: center; } }
</style>

<div class="upload-card">
  <input type="file" id="excelInput" accept=".xlsx, .xls" style="display:none" />
  <button class="btn primary" id="uploadBtn"><i class="fas fa-upload"></i> رفع ملف Excel (شاحنات)</button>
  <button class="btn soft" id="saveReportBtn"><i class="fas fa-save"></i> حفظ التقرير الحالي</button>
  <button class="btn soft" id="refreshReportsListBtn"><i class="fas fa-sync-alt"></i> عرض التقارير المحفوظة</button>
  <button class="btn danger soft" id="clearReportsBtn"><i class="fas fa-trash-alt"></i> مسح جميع التقارير</button>
  <button class="btn soft" id="exportExcelBtn"><i class="fas fa-file-excel"></i> تصدير Excel (تفصيل شامل)</button>
</div>

<div id="reminderBox" class="reminder-box">⚠️ تم رفع الملف وعرض البيانات، لكن لم يتم حفظه بعد! اضغط على "حفظ التقرير الحالي" لحفظه محلياً.</div>

<div id="reportsPanel" class="reports-panel" style="display:none;">
  <div class="selection-bar">
    <span>📌 المحدد: <span id="selectedCount" class="selected-count">0</span> تقرير</span>
    <button id="mergeSelectedBtn" class="btn primary" style="display:none;"><i class="fas fa-layer-group"></i> دمج المحدد</button>
  </div>
  <div id="savedReportsList" class="reports-list"></div>
  <div class="muted" style="margin-top:0.5rem; font-size:0.7rem;">✅ حدد تقريرين أو أكثر بالضغط على المربع ثم اضغط "دمج المحدد"</div>
</div>

<div id="currentDashboard">
  <div class="kpi-grid" id="kpiContainer"></div>
  <div class="table-responsive" id="dataTableContainer"></div>
  <div style="margin-top:30px;"><h3>🔝 أعلى 10 سيارات في بنود المصاريف</h3><div id="topExpensesDetails" class="top-categories-grid"></div></div>
  <div class="chart-grid">
    <div class="chart-card"><h3>📊 أعلى 10 مصروفات</h3><canvas id="topExpensesChart"></canvas></div>
    <div class="chart-card"><h3>📉 أقل 10 مصروفات</h3><canvas id="bottomExpensesChart"></canvas></div>
    <div class="chart-card"><h3>💰 أعلى 10 إيرادات</h3><canvas id="topRevenueChart"></canvas></div>
    <div class="chart-card"><h3>📉 أقل 10 إيرادات</h3><canvas id="bottomRevenueChart"></canvas></div>
  </div>
</div>

<!-- مكتبات -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="https://cdn.sheetjs.com/xlsx-0.20.2/package/dist/xlsx.full.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/exceljs@4.4.0/dist/exceljs.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/file-saver@2.0.5/dist/FileSaver.min.js"></script>

<script>
  // ========== بيانات الشاحنات والمصاريف (مثل السابق) ==========
  const truckInfoMap = { /* كامل كما هو */ };
  const expenseCategories = [
    { key: "diesel", name: "الديزل" }, { key: "spareParts", name: "قطع غيار" }, { key: "tires", name: "كفرات وجنوط" },
    { key: "batteries", name: "البطاريات" }, { key: "oils", name: "الزيوت" }, { key: "insurance", name: "تأمين شامل" },
    { key: "salaries", name: "المرتبات" }, { key: "roadSide", name: "بنشر طريق" }, { key: "admin", name: "عمومية وإدارية" }
  ];
  let currentVehicleData = [];
  let savedReports = [];
  let selectedReportIds = new Set();
  let charts = {};
  let hasUnsavedData = false;
  const STORAGE_KEY_REPORTS = 'expenses_reports';

  // === دوال مساعدة (مختصرة ولكن كاملة) ===
  function formatNumber(n) { return (n||0).toLocaleString('en-US', {minimumFractionDigits:2, maximumFractionDigits:2}); }
  function showToast(msg, type) { let c = document.getElementById('toastContainer'); if(!c){c=document.createElement('div');c.id='toastContainer';document.body.appendChild(c);} let t=document.createElement('div'); t.className=`toast ${type}`; t.innerText=msg; c.appendChild(t); setTimeout(()=>t.remove(),3000); }
  function showLoading(show) { let l=document.getElementById('globalLoader'); if(show){ if(!l){ l=document.createElement('div'); l.id='globalLoader'; l.innerHTML='<div class="spinner"></div>'; document.body.appendChild(l); } } else if(l) l.remove(); }
  function parseNumeric(v){ if(typeof v==='number') return v; let n=parseFloat(String(v).replace(/[^0-9.-]/g,'')); return isNaN(n)?0:n; }
  function getTruckInfo(p){ return truckInfoMap[p]||{brand:"غير معروف",year:"—"}; }
  function cleanTruckId(r){ let m=r.match(/\d{4}/); if(m){ for(let k in truckInfoMap) if(k.includes(m[0])) return k; return m[0]; } return r; }
  function findExpenseCols(headers){ let map={}; for(let cat of expenseCategories){ let idx=-1; for(let i=0;i<headers.length;i++){ let h=headers[i].toString().trim(); if(h===cat.name||h.includes(cat.name)){idx=i;break;} } if(idx===-1){ for(let i=0;i<headers.length;i++){ let h=headers[i].toLowerCase(); if((cat.key==='diesel'&&(h.includes('ديزل')))||(cat.key==='spareParts'&&(h.includes('قطع غيار')))||(cat.key==='tires'&&(h.includes('كفرات')))||(cat.key==='batteries'&&(h.includes('بطاريات')))||(cat.key==='oils'&&(h.includes('زيوت')))||(cat.key==='insurance'&&(h.includes('تأمين')))||(cat.key==='salaries'&&(h.includes('مرتبات')))||(cat.key==='roadSide'&&(h.includes('بنشر')))||(cat.key==='admin'&&(h.includes('عمومية')||h.includes('إدارية')))) { idx=i; break; } } } map[cat.key]=idx; } return map; }

  async function processExcelFile(file) {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = e => {
        const data = new Uint8Array(e.target.result);
        const wb = XLSX.read(data, { type: 'array' });
        const sheet = wb.Sheets[wb.SheetNames[0]];
        const rows = XLSX.utils.sheet_to_json(sheet, { header: 1, defval: "" });
        let headerRow = -1;
        for(let i=0;i<Math.min(rows.length,30);i++) if(rows[i] && rows[i].join(" ").toLowerCase().includes("مركز التكلفة")) { headerRow=i; break; }
        if(headerRow===-1) headerRow=0;
        const headers = rows[headerRow].map(c=>c.toString().trim());
        const findCol = kw => { for(let i=0;i<headers.length;i++) for(let k of kw) if(headers[i].toLowerCase().includes(k)) return i; return -1; };
        let colCost = findCol(['مركز تكلفة','تكلفة']);
        let colExp = findCol(['الجملة','اجمالي المصروفات','المصروفات']);
        let colRev = findCol(['الايراد','الإيراد']);
        let colNet = findCol(['الصافي','صافي']);
        if(colCost===-1||colExp===-1||colRev===-1||colNet===-1) reject("الأعمدة الأساسية غير موجودة");
        const expCols = findExpenseCols(headers);
        let vehicles = [];
        for(let r=headerRow+1; r<rows.length; r++){
          let row = rows[r];
          if(!row || row.length===0) continue;
          let costRaw = row[colCost]?String(row[colCost]).trim():"";
          if(!costRaw || costRaw.includes("الإجمالي")) continue;
          let expense = parseNumeric(row[colExp]);
          let revenue = parseNumeric(row[colRev]);
          let net = parseNumeric(row[colNet]);
          if(expense===0 && revenue===0) continue;
          let details = {};
          for(let cat of expenseCategories) details[cat.key] = expCols[cat.key]!==-1 ? parseNumeric(row[expCols[cat.key]]) : 0;
          let plate = cleanTruckId(costRaw);
          let info = getTruckInfo(plate);
          vehicles.push({ plateCode:plate, brand:info.brand, year:info.year, totalExpense:expense, totalRevenue:revenue, netIncome:net, netPercent: revenue? (net/revenue)*100:0, expenseDetails:details, tripCount:0, weight:0 });
        }
        if(!vehicles.length) reject("لا توجد بيانات صالحة");
        resolve(vehicles);
      };
      reader.onerror = () => reject("خطأ قراءة الملف");
      reader.readAsArrayBuffer(file);
    });
  }

  function renderDashboard(data){
    if(!data.length) return;
    let sorted = [...data].sort((a,b)=>a.netPercent-b.netPercent);
    let totalExp = sorted.reduce((s,v)=>s+v.totalExpense,0);
    let totalRev = sorted.reduce((s,v)=>s+v.totalRevenue,0);
    let totalNet = sorted.reduce((s,v)=>s+v.netIncome,0);
    let avgPerc = totalRev ? (totalNet/totalRev)*100 : 0;
    document.getElementById("kpiContainer").innerHTML = `<div class="kpi-card"><div class="kpi-value">${formatNumber(totalExp)} ر.س</div><div>إجمالي المصروفات</div></div><div class="kpi-card"><div class="kpi-value">${formatNumber(totalRev)} ر.س</div><div>إجمالي الإيرادات</div></div><div class="kpi-card"><div class="kpi-value">${formatNumber(totalNet)} ر.س</div><div>صافي الدخل الكلي</div></div><div class="kpi-card"><div class="kpi-value">${avgPerc.toFixed(2)}%</div><div>متوسط نسبة الصافي</div></div>`;
    let html = `<table><thead><tr><th>الماركة</th><th>سنة الإنتاج</th><th>رقم اللوحة</th><th>إجمالي المصروف</th><th>إجمالي الإيراد</th><th>صافي الإيراد</th><th>نسبة الصافي%</th></tr></thead><tbody>`;
    sorted.forEach(v=>{ let cls = v.netPercent<29?'net-percent-red':(v.netPercent<=35?'net-percent-yellow':'net-percent-green'); html+=`<tr><td>${v.brand}</td><td>${v.year}</td><td>${v.plateCode}</td><td>${formatNumber(v.totalExpense)}</td><td>${formatNumber(v.totalRevenue)}</td><td>${formatNumber(v.netIncome)}</td><td class="${cls}">${v.netPercent.toFixed(2)}%</td></tr>`; });
    html+=`</tbody>${'</table>'}`;
    document.getElementById("dataTableContainer").innerHTML = html;
    // جعل اعلى 10 فئات
    let container = document.getElementById("topExpensesDetails");
    container.innerHTML = "";
    for(let cat of expenseCategories){
      let sortedBy = [...data].sort((a,b)=>(b.expenseDetails[cat.key]||0)-(a.expenseDetails[cat.key]||0)).slice(0,10);
      let card = document.createElement("div"); card.className="top-category-card";
      card.innerHTML = `<h4>${cat.name}</h4><div class="table-wrap"><table><thead><tr><th>#</th><th>اللوحة</th><th>القيمة</th></tr></thead><tbody>${sortedBy.map((v,i)=>`<tr><td>${i+1}</td><td>${v.plateCode}</td><td>${formatNumber(v.expenseDetails[cat.key]||0)}</td></tr>`).join('')}</tbody></table></div>`;
      container.appendChild(card);
    }
    // تحديث المخططات
    let topExp = [...data].sort((a,b)=>b.totalExpense-a.totalExpense).slice(0,10);
    let bottomExp = [...data].sort((a,b)=>a.totalExpense-b.totalExpense).slice(0,10);
    let topRev = [...data].sort((a,b)=>b.totalRevenue-a.totalRevenue).slice(0,10);
    let bottomRev = [...data].sort((a,b)=>a.totalRevenue-b.totalRevenue).slice(0,10);
    if(charts.topExp) charts.topExp.destroy();
    if(charts.bottomExp) charts.bottomExp.destroy();
    if(charts.topRev) charts.topRev.destroy();
    if(charts.bottomRev) charts.bottomRev.destroy();
    let textColor = getComputedStyle(document.body).getPropertyValue('--text-primary') || '#333';
    charts.topExp = new Chart(document.getElementById('topExpensesChart'), { type:'bar', data:{ labels:topExp.map(v=>v.plateCode), datasets:[{ label:'المصروف', data:topExp.map(v=>v.totalExpense), backgroundColor:'#f093fb' }] }, options:{ responsive:true, maintainAspectRatio:false, plugins:{ legend:{ labels:{ color:textColor } } } } });
    charts.bottomExp = new Chart(document.getElementById('bottomExpensesChart'), { type:'bar', data:{ labels:bottomExp.map(v=>v.plateCode), datasets:[{ label:'أقل مصروف', data:bottomExp.map(v=>v.totalExpense), backgroundColor:'#667eea' }] }, options:{ responsive:true, maintainAspectRatio:false, plugins:{ legend:{ labels:{ color:textColor } } } } });
    charts.topRev = new Chart(document.getElementById('topRevenueChart'), { type:'bar', data:{ labels:topRev.map(v=>v.plateCode), datasets:[{ label:'الإيراد', data:topRev.map(v=>v.totalRevenue), backgroundColor:'#11998e' }] }, options:{ responsive:true, maintainAspectRatio:false, plugins:{ legend:{ labels:{ color:textColor } } } } });
    charts.bottomRev = new Chart(document.getElementById('bottomRevenueChart'), { type:'bar', data:{ labels:bottomRev.map(v=>v.plateCode), datasets:[{ label:'أقل إيراد', data:bottomRev.map(v=>v.totalRevenue), backgroundColor:'#eb3349' }] }, options:{ responsive:true, maintainAspectRatio:false, plugins:{ legend:{ labels:{ color:textColor } } } } });
  }

  // === دوال التخزين المحلي ===
  function saveReportsToStorage(){ localStorage.setItem(STORAGE_KEY_REPORTS, JSON.stringify(savedReports.map(r=>({id:r.id,reportName:r.reportName,createdAt:r.createdAt,data:r.data})))); }
  function loadReportsFromStorage(){ let s=localStorage.getItem(STORAGE_KEY_REPORTS); savedReports = s? JSON.parse(s) : []; }
  async function saveCurrentReport(){ if(!currentVehicleData.length){ alert("لا يوجد تقرير محمّل"); return; } let name=prompt("اسم التقرير:",`تقرير ${new Date().toLocaleDateString()}`); if(!name) return; showLoading(true); try{ savedReports.push({ id:Date.now(), reportName:name, createdAt:new Date().toISOString(), data:currentVehicleData }); saveReportsToStorage(); showToast("تم الحفظ بنجاح","success"); await loadAndDisplayReportsList(); hasUnsavedData=false; updateReminder(); }catch(e){ showToast(e.message,"error"); } finally{ showLoading(false); } }
  async function deleteReport(id){ savedReports=savedReports.filter(r=>r.id!=id); saveReportsToStorage(); await loadAndDisplayReportsList(); showToast("تم حذف التقرير","success"); }
  async function updateReportName(id,newName){ let r=savedReports.find(r=>r.id==id); if(r){ r.reportName=newName; saveReportsToStorage(); await loadAndDisplayReportsList(); showToast("تم التعديل","success"); } }
  async function clearAllReports(){ if(confirm("مسح جميع التقارير؟")){ savedReports=[]; localStorage.removeItem(STORAGE_KEY_REPORTS); selectedReportIds.clear(); await loadAndDisplayReportsList(); showToast("تم مسح الكل","success"); document.getElementById("reportsPanel").style.display="none"; } }
  function updateSelectionBar(){ let cnt=selectedReportIds.size; document.getElementById('selectedCount').innerText=cnt; document.getElementById('mergeSelectedBtn').style.display = cnt>=2 ? 'inline-block' : 'none'; }
  function toggleSelect(id,checked){ if(checked) selectedReportIds.add(id); else selectedReportIds.delete(id); updateSelectionBar(); document.querySelectorAll('.report-card').forEach(card=>{ let ch=card.querySelector('.report-checkbox'); if(ch && ch.checked) card.classList.add('selected'); else card.classList.remove('selected'); }); }
  async function loadAndDisplayReportsList(){ loadReportsFromStorage(); let container=document.getElementById("savedReportsList"); if(!container) return; container.innerHTML=""; if(savedReports.length===0){ container.innerHTML="<div class='muted center'>لا توجد تقارير محفوظة</div>"; document.getElementById("reportsPanel").style.display="none"; return; } document.getElementById("reportsPanel").style.display="block"; savedReports.forEach(r=>{ let card=document.createElement("div"); card.className="report-card"; if(selectedReportIds.has(r.id)) card.classList.add("selected"); let chk=document.createElement("input"); chk.type="checkbox"; chk.className="report-checkbox"; chk.checked=selectedReportIds.has(r.id); chk.onclick=(e)=>{ e.stopPropagation(); toggleSelect(r.id,chk.checked); }; let nameSpan=document.createElement("span"); nameSpan.className="report-name"; nameSpan.innerText=r.reportName; let dateSpan=document.createElement("span"); dateSpan.className="report-date"; dateSpan.innerText=new Date(r.createdAt).toLocaleDateString('ar-EG'); let actions=document.createElement("div"); actions.className="report-actions"; let editBtn=document.createElement("button"); editBtn.innerText="✏️ تعديل"; editBtn.onclick=(e)=>{ e.stopPropagation(); let nn=prompt("اسم جديد:",r.reportName); if(nn && nn!==r.reportName) updateReportName(r.id,nn); }; let delBtn=document.createElement("button"); delBtn.innerText="🗑️ حذف"; delBtn.onclick=(e)=>{ e.stopPropagation(); if(confirm("حذف التقرير؟")) deleteReport(r.id); }; actions.appendChild(editBtn); actions.appendChild(delBtn); let viewBtn=document.createElement("button"); viewBtn.innerText="👁️ عرض التقرير"; viewBtn.className="view-report-btn"; viewBtn.onclick=(e)=>{ e.stopPropagation(); currentVehicleData=r.data; renderDashboard(currentVehicleData); hasUnsavedData=false; updateReminder(); showToast(`تم عرض: ${r.reportName}`,"success"); }; card.appendChild(chk); card.appendChild(nameSpan); card.appendChild(dateSpan); card.appendChild(actions); card.appendChild(viewBtn); container.appendChild(card); }); updateSelectionBar(); }

  async function mergeSelectedReports(){ if(selectedReportIds.size<2){ showToast("اختر تقريرين على الأقل","error"); return; } let reports = savedReports.filter(r=>selectedReportIds.has(r.id)); if(!confirm(`دمج التقارير التالية؟\n${reports.map(r=>r.reportName).join('\n')}`)) return; showLoading(true); try{ let map=new Map(); for(let rep of reports){ for(let v of rep.data){ let key=v.plateCode; if(!map.has(key)){ map.set(key,{ brand:v.brand, year:v.year, plateCode:key, expense:0, revenue:0, net:0, details:{}, tripCount:0, weight:0 }); for(let cat of expenseCategories) map.get(key).details[cat.key]=0; } let t=map.get(key); t.expense+=v.totalExpense; t.revenue+=v.totalRevenue; t.net+=v.netIncome; for(let cat of expenseCategories) t.details[cat.key]+=(v.expenseDetails?.[cat.key]||0); } } let merged = Array.from(map.values()).map(v=>({ plateCode:v.plateCode, brand:v.brand, year:v.year, totalExpense:v.expense, totalRevenue:v.revenue, netIncome:v.net, netPercent:v.revenue? (v.net/v.revenue)*100 :0, expenseDetails:v.details, tripCount:v.tripCount, weight:v.weight })); merged.sort((a,b)=>a.netPercent-b.netPercent); currentVehicleData=merged; renderDashboard(currentVehicleData); let newReport = { id:Date.now(), reportName:`دمج (${reports.map(r=>r.reportName).join(' + ')})`, createdAt:new Date().toISOString(), data:merged }; savedReports.push(newReport); saveReportsToStorage(); selectedReportIds.clear(); await loadAndDisplayReportsList(); hasUnsavedData=false; updateReminder(); showToast("تم الدمج","success"); }catch(e){ showToast(e.message,"error"); } finally{ showLoading(false); } }

  function updateReminder(){ document.getElementById('reminderBox').style.display = (hasUnsavedData && currentVehicleData.length) ? 'block' : 'none'; }

  // ========== دالة تصدير Excel متكاملة ==========
  async function exportFullExcel() {
    if (!currentVehicleData.length) { alert("لا توجد بيانات للتصدير"); return; }
    showLoading(true);
    try {
      const ExcelJS = window.ExcelJS;
      if (!ExcelJS) throw new Error('ExcelJS لم يتم تحميله');
      const workbook = new ExcelJS.Workbook();
      workbook.creator = 'مجموعة شركات زرعة الخير';
      // 1. ورقة ملخص شهري (بناءً على التقارير المحفوظة إن وجدت)
      const monthlyData = savedReports.length ? savedReports.map(r => ({ name: r.reportName, totalExp: r.data.reduce((s,v)=>s+v.totalExpense,0), totalRev: r.data.reduce((s,v)=>s+v.totalRevenue,0), totalNet: r.data.reduce((s,v)=>s+v.netIncome,0) })) : [{ name: "التقرير الحالي", totalExp: currentVehicleData.reduce((s,v)=>s+v.totalExpense,0), totalRev: currentVehicleData.reduce((s,v)=>s+v.totalRevenue,0), totalNet: currentVehicleData.reduce((s,v)=>s+v.netIncome,0) }];
      const wsMonthly = workbook.addWorksheet("ملخص شهري");
      styleSheet(wsMonthly, "ملخص شهري", [{ header:"التقرير", width:25 }, { header:"إجمالي المصروفات", width:22 }, { header:"إجمالي الإيرادات", width:22 }, { header:"صافي الدخل", width:22 }, { header:"نسبة الصافي %", width:18 }], monthlyData.map(m => [m.name, m.totalExp, m.totalRev, m.totalNet, m.totalRev ? (m.totalNet/m.totalRev)/100 : 0]), [1,2,3], [4]);
      
      // 2. ملخص إجمالي المصاريف
      let totalDetails = {}; for(let cat of expenseCategories) totalDetails[cat.key]=0;
      for(let v of currentVehicleData) for(let cat of expenseCategories) totalDetails[cat.key]+=(v.expenseDetails[cat.key]||0);
      let summaryRows = expenseCategories.map(cat=>[cat.name, totalDetails[cat.key]]);
      summaryRows.push(["إجمالي المصروفات الكلي", currentVehicleData.reduce((s,v)=>s+v.totalExpense,0)]);
      summaryRows.push(["إجمالي الإيرادات الكلي", currentVehicleData.reduce((s,v)=>s+v.totalRevenue,0)]);
      summaryRows.push(["صافي الدخل الكلي", currentVehicleData.reduce((s,v)=>s+v.netIncome,0)]);
      const wsSummary = workbook.addWorksheet("ملخص إجمالي المصاريف");
      styleSheet(wsSummary, "ملخص إجمالي المصاريف", [{ header:"بند المصروف", width:25 }, { header:"الإجمالي (ر.س)", width:22 }], summaryRows, [1]);
      
      // 3. تفصيل المصاريف لكل شاحنة
      let allTrucks = [...currentVehicleData].sort((a,b)=>parseInt(a.plateCode.match(/\d+/)?.[0]||0)-parseInt(b.plateCode.match(/\d+/)?.[0]||0));
      let detailCols = [{ header:"الماركة", width:15 }, { header:"السنة", width:10 }, { header:"رقم اللوحة", width:18 }, ...expenseCategories.map(cat=>({ header:cat.name, width:16 })), { header:"إجمالي المصروفات", width:20 }, { header:"إجمالي الإيرادات", width:20 }, { header:"صافي الدخل", width:18 }, { header:"نسبة الصافي %", width:16 }];
      let detailRows = allTrucks.map(v=>{
        let row = [v.brand, v.year, v.plateCode];
        for(let cat of expenseCategories) row.push(v.expenseDetails[cat.key]||0);
        row.push(v.totalExpense, v.totalRevenue, v.netIncome, v.netPercent/100);
        return row;
      });
      const wsDetail = workbook.addWorksheet("تفصيل المصاريف لكل شاحنة");
      let numericDetailIndices = [3,4,5,6,7,8,9,10,11]; // حسب عدد الفئات + 3
      styleSheet(wsDetail, "تفصيل المصاريف لكل شاحنة", detailCols, detailRows, numericDetailIndices, [detailCols.length-1], true, detailCols.length-1);
      
      // 4. أعلى 10 في بنود المصاريف (ورقة منفصلة)
      const wsTop = workbook.addWorksheet("أعلى 10 في بنود المصاريف");
      wsTop.views = [{ rightToLeft: true }];
      let currentRow = 1;
      wsTop.mergeCells('A1:D1'); wsTop.getCell('A1').value = "أعلى 10 سيارات في كل بند من بنود المصاريف"; wsTop.getCell('A1').font = { size:16, bold:true }; wsTop.getCell('A1').fill = { type:'pattern', pattern:'solid', fgColor:{ argb:'FFD9EAD3' } }; wsTop.getCell('A1').alignment = { horizontal:'center' }; wsTop.getRow(1).height = 35; currentRow=2;
      for(let cat of expenseCategories){
        wsTop.mergeCells(`A${currentRow}:D${currentRow}`); wsTop.getCell(`A${currentRow}`).value = cat.name; wsTop.getCell(`A${currentRow}`).font = { size:14, bold:true }; wsTop.getCell(`A${currentRow}`).fill = { type:'pattern', pattern:'solid', fgColor:{ argb:'FFE6F0D8' } }; currentRow++;
        let headers = ["#", "رقم اللوحة", "القيمة (ر.س)"]; 
        for(let i=0;i<3;i++){ let cell = wsTop.getRow(currentRow).getCell(i+1); cell.value = headers[i]; cell.fill = { type:'pattern', pattern:'solid', fgColor:{ argb:'FFC5E0B4' } }; cell.font = { bold:true }; } currentRow++;
        let sorted = [...allTrucks].sort((a,b)=>(b.expenseDetails[cat.key]||0)-(a.expenseDetails[cat.key]||0)).slice(0,10);
        for(let idx=0; idx<sorted.length; idx++){
          let row = wsTop.getRow(currentRow);
          row.getCell(1).value = idx+1; row.getCell(2).value = sorted[idx].plateCode; row.getCell(3).value = sorted[idx].expenseDetails[cat.key]||0; row.getCell(3).numFmt = '#,##0.00';
          currentRow++;
        }
        if(sorted.length===0){ wsTop.getRow(currentRow).getCell(2).value = "لا توجد بيانات"; currentRow++; }
        currentRow++;
      }
      wsTop.columns = [{ width:8 }, { width:22 }, { width:20 }];
      
      // 5. أقل 10 في بنود المصاريف (بنفس الطريقة)
      const wsLowest = workbook.addWorksheet("أقل 10 في بنود المصاريف");
      wsLowest.views = [{ rightToLeft: true }];
      currentRow=1; wsLowest.mergeCells('A1:D1'); wsLowest.getCell('A1').value = "أقل 10 سيارات في كل بند من بنود المصاريف"; wsLowest.getCell('A1').font = { size:16, bold:true }; wsLowest.getCell('A1').fill = { type:'pattern', pattern:'solid', fgColor:{ argb:'FFD9EAD3' } }; wsLowest.getCell('A1').alignment = { horizontal:'center' }; wsLowest.getRow(1).height = 35; currentRow=2;
      for(let cat of expenseCategories){
        wsLowest.mergeCells(`A${currentRow}:D${currentRow}`); wsLowest.getCell(`A${currentRow}`).value = cat.name; wsLowest.getCell(`A${currentRow}`).font = { size:14, bold:true }; wsLowest.getCell(`A${currentRow}`).fill = { type:'pattern', pattern:'solid', fgColor:{ argb:'FFE6F0D8' } }; currentRow++;
        for(let i=0;i<3;i++){ let cell = wsLowest.getRow(currentRow).getCell(i+1); cell.value = ["#", "رقم اللوحة", "القيمة (ر.س)"][i]; cell.fill = { type:'pattern', pattern:'solid', fgColor:{ argb:'FFC5E0B4' } }; cell.font = { bold:true }; } currentRow++;
        let sorted = [...allTrucks].sort((a,b)=>(a.expenseDetails[cat.key]||0)-(b.expenseDetails[cat.key]||0)).slice(0,10);
        for(let idx=0; idx<sorted.length; idx++){
          let row = wsLowest.getRow(currentRow);
          row.getCell(1).value = idx+1; row.getCell(2).value = sorted[idx].plateCode; row.getCell(3).value = sorted[idx].expenseDetails[cat.key]||0; row.getCell(3).numFmt = '#,##0.00';
          currentRow++;
        }
        if(sorted.length===0){ wsLowest.getRow(currentRow).getCell(2).value = "لا توجد بيانات"; currentRow++; }
        currentRow++;
      }
      wsLowest.columns = [{ width:8 }, { width:22 }, { width:20 }];
      
      // 6. أهم 10 سيارات (مصروفات، ايرادات، صافي)
      const wsImportant = workbook.addWorksheet("أهم 10 سيارات");
      wsImportant.views = [{ rightToLeft: true }];
      currentRow=1; wsImportant.mergeCells('A1:F1'); wsImportant.getCell('A1').value = "أهم 10 سيارات (مصروفات، إيرادات، صافي أرباح)"; wsImportant.getCell('A1').font = { size:16, bold:true }; wsImportant.getCell('A1').fill = { type:'pattern', pattern:'solid', fgColor:{ argb:'FFD9EAD3' } }; wsImportant.getCell('A1').alignment = { horizontal:'center' }; wsImportant.getRow(1).height = 35; currentRow=2;
      let sections = [
        { title:"💰 أعلى 10 مصروفات", data:[...allTrucks].sort((a,b)=>b.totalExpense-a.totalExpense).slice(0,10), cols:["#","رقم اللوحة","المصروفات"] },
        { title:"📉 أقل 10 مصروفات", data:[...allTrucks].sort((a,b)=>a.totalExpense-b.totalExpense).slice(0,10), cols:["#","رقم اللوحة","المصروفات"] },
        { title:"📈 أكثر 10 إيرادات", data:[...allTrucks].sort((a,b)=>b.totalRevenue-a.totalRevenue).slice(0,10), cols:["#","رقم اللوحة","الإيرادات"] },
        { title:"📉 أقل 10 إيرادات", data:[...allTrucks].sort((a,b)=>a.totalRevenue-b.totalRevenue).slice(0,10), cols:["#","رقم اللوحة","الإيرادات"] },
        { title:"🏆 أكثر 10 صافي أرباح", data:[...allTrucks].sort((a,b)=>b.netIncome-a.netIncome).slice(0,10), cols:["#","رقم اللوحة","صافي الربح"] },
        { title:"⚠️ أقل 10 صافي أرباح", data:[...allTrucks].sort((a,b)=>a.netIncome-b.netIncome).slice(0,10), cols:["#","رقم اللوحة","صافي الربح"] }
      ];
      for(let sec of sections){
        wsImportant.mergeCells(`A${currentRow}:C${currentRow}`); wsImportant.getCell(`A${currentRow}`).value = sec.title; wsImportant.getCell(`A${currentRow}`).font = { size:14, bold:true }; wsImportant.getCell(`A${currentRow}`).fill = { type:'pattern', pattern:'solid', fgColor:{ argb:'FFE6F0D8' } }; currentRow++;
        for(let i=0;i<3;i++){ let cell = wsImportant.getRow(currentRow).getCell(i+1); cell.value = sec.cols[i]; cell.fill = { type:'pattern', pattern:'solid', fgColor:{ argb:'FFC5E0B4' } }; cell.font = { bold:true }; } currentRow++;
        for(let idx=0; idx<sec.data.length; idx++){
          let row = wsImportant.getRow(currentRow);
          row.getCell(1).value = idx+1; row.getCell(2).value = sec.data[idx].plateCode;
          let val = sec.cols[2].includes("المصروفات") ? sec.data[idx].totalExpense : (sec.cols[2].includes("الإيرادات") ? sec.data[idx].totalRevenue : sec.data[idx].netIncome);
          row.getCell(3).value = val; row.getCell(3).numFmt = '#,##0.00';
          currentRow++;
        }
        if(sec.data.length===0){ wsImportant.getRow(currentRow).getCell(2).value = "لا توجد بيانات"; currentRow++; }
        currentRow++;
      }
      wsImportant.columns = [{ width:8 }, { width:22 }, { width:22 }];
      
      // 7. إجمالي الشاحنات مبسط
      const wsSimple = workbook.addWorksheet("إجمالي الشاحنات (مبسط)");
      let simpleRows = allTrucks.map(v=>[v.brand, v.year, v.plateCode, v.totalExpense, v.totalRevenue, v.netIncome, v.netPercent/100]);
      styleSheet(wsSimple, "إجمالي الشاحنات (مبسط)", [{ header:"الماركة", width:15 }, { header:"السنة", width:10 }, { header:"رقم اللوحة", width:18 }, { header:"إجمالي المصروفات", width:20 }, { header:"إجمالي الإيرادات", width:20 }, { header:"صافي الدخل", width:18 }, { header:"نسبة الصافي %", width:16 }], simpleRows, [3,4,5], [6], true, 6);
      
      // ترتيب الأوراق
      let sheetOrder = ["ملخص شهري", "ملخص إجمالي المصاريف", "تفصيل المصاريف لكل شاحنة", "أعلى 10 في بنود المصاريف", "أقل 10 في بنود المصاريف", "أهم 10 سيارات", "إجمالي الشاحنات (مبسط)"];
      workbook.eachSheet((sheet, id) => { let idx = sheetOrder.indexOf(sheet.name); if(idx!==-1 && sheet.order!==idx) sheet.order = idx; });
      workbook.worksheets.sort((a,b)=>(a.order||999)-(b.order||999));
      
      const buffer = await workbook.xlsx.writeBuffer();
      saveAs(new Blob([buffer]), `تقرير_سيارات_${new Date().toISOString().slice(0,10)}.xlsx`);
      showToast("✅ تم تصدير التقرير بنجاح", "success");
    } catch(err) { console.error(err); showToast("خطأ في التصدير: "+err.message, "error"); }
    finally { showLoading(false); }
  }
  
  function styleSheet(ws, title, columns, rows, numericIndices=[], percentIndices=[], setPageSetup=true, conditionalCol=-1){
    ws.views = [{ rightToLeft: true }];
    if(setPageSetup) ws.pageSetup = { paperSize:9, orientation:'portrait', fitToPage:true, fitToWidth:1, fitToHeight:0 };
    ws.mergeCells(`A1:${String.fromCharCode(64+columns.length)}1`);
    ws.getCell('A1').value = title; ws.getCell('A1').font = { size:16, bold:true, color:{ argb:'FF000000' } }; ws.getCell('A1').fill = { type:'pattern', pattern:'solid', fgColor:{ argb:'FFD9EAD3' } }; ws.getCell('A1').alignment = { horizontal:'center', vertical:'middle' }; ws.getRow(1).height = 40;
    let headerRow = ws.addRow(columns.map(c=>c.header));
    headerRow.eachCell(cell => { cell.fill = { type:'pattern', pattern:'solid', fgColor:{ argb:'FFC5E0B4' } }; cell.font = { bold:true, size:12, color:{ argb:'FF000000' } }; cell.border = { top:{style:'thin'}, bottom:{style:'thin'}, left:{style:'thin'}, right:{style:'thin'} }; cell.alignment = { horizontal:'center' }; });
    rows.forEach((rowData, idx) => {
      let row = ws.addRow(rowData);
      row.eachCell((cell, colIdx) => { cell.border = { top:{style:'thin'}, bottom:{style:'thin'}, left:{style:'thin'}, right:{style:'thin'} }; cell.alignment = { horizontal:'center' }; if(numericIndices.includes(colIdx-1) && typeof rowData[colIdx-1]==='number') cell.numFmt = '#,##0.00'; if(percentIndices.includes(colIdx-1) && typeof rowData[colIdx-1]==='number') cell.numFmt = '0.00%'; });
      row.eachCell((cell, colIdx) => { if(idx%2===0) cell.fill = { type:'pattern', pattern:'solid', fgColor:{ argb:'FFF9F9F9' } }; else cell.fill = { type:'pattern', pattern:'solid', fgColor:{ argb:'FFFFFFFF' } }; });
      if(conditionalCol !== -1 && rowData[conditionalCol] !== undefined){
        let percent = parseFloat(rowData[conditionalCol]);
        let target = row.getCell(conditionalCol+1);
        if(!isNaN(percent)){ if(percent < 0.29) target.font = { color:{ argb:'FFEB3349' }, bold:true }; else if(percent <= 0.35) target.font = { color:{ argb:'FFF4A100' }, bold:true }; else target.font = { color:{ argb:'FF11998E' }, bold:true }; }
      }
    });
    ws.columns = columns.map(col => ({ width: col.width || 18 }));
  }

  // ربط الأحداث
  document.getElementById("uploadBtn").onclick = () => document.getElementById("excelInput").click();
  document.getElementById("excelInput").onchange = async (e) => {
    let file = e.target.files[0]; if(!file) return;
    showLoading(true);
    try{
      let data = await processExcelFile(file);
      currentVehicleData = data;
      renderDashboard(data);
      hasUnsavedData = true;
      updateReminder();
      showToast(`✅ تم تحليل ${data.length} سيارة، تذكر حفظ التقرير!`,"success");
    }catch(err){ showToast(err.message,"error"); }
    finally{ showLoading(false); }
  };
  document.getElementById("saveReportBtn").onclick = saveCurrentReport;
  document.getElementById("refreshReportsListBtn").onclick = async () => { await loadAndDisplayReportsList(); };
  document.getElementById("mergeSelectedBtn").onclick = mergeSelectedReports;
  document.getElementById("clearReportsBtn").onclick = clearAllReports;
  document.getElementById("exportExcelBtn").onclick = exportFullExcel;
  
  (async function init(){ await loadAndDisplayReportsList(); })();
</script>
function renderFactoryOrders(req, res) {
  try {
    const user = req.session.user;
    const factories = db.prepare('SELECT id, name, distance_km, city FROM factories WHERE is_active = 1 ORDER BY name').all();
    const materials = db.prepare('SELECT id, name FROM materials WHERE is_active = 1 ORDER BY name').all();
    let factory = null;
    let where = '';
    const params = [];

    if (user.role === 'factory' && user.factory_id) {
      factory = db.prepare('SELECT * FROM factories WHERE id = ?').get(user.factory_id);
      where = 'WHERE o.factory_id = ?';
      params.push(user.factory_id);
    }

    const orders = db.prepare(`
      SELECT o.id, o.requested_time, o.quantity, o.status, o.notes,
             m.name AS material_name,
             COALESCE(a.truck_number, t.plate_number, '') AS truck_number,
             COALESCE(d.name, t.driver_name, '') AS driver_name
      FROM orders o
      LEFT JOIN materials m ON o.material_id = m.id
      LEFT JOIN assignments a ON a.order_id = o.id
      LEFT JOIN drivers d ON a.driver_id = d.id
      LEFT JOIN trucks t ON d.current_truck_id = t.id
      ${where}
      ORDER BY o.created_at DESC, o.id DESC
      LIMIT 200
    `).all(...params);

    res.render('factory_orders', {
      title: 'طلبات المصنع',
      user,
      currentPath: '/factory_orders',
      factory,
      factories,
      materials,
      orders
    });
  } catch (err) {
    res.status(500).send('خطأ في تحميل طلبات المصنع: ' + err.message);
  }
}

app.get('/factory_orders', requireAuth, renderFactoryOrders);
app.get('/factory/orders', requireAuth, renderFactoryOrders);

app.post('/factory/orders', requireAuth, (req, res) => {
  try {
    const user = req.session.user;
    const factoryId = user.role === 'factory' ? user.factory_id : Number(req.body.factory_id);
    const materialId = Number(req.body.material_id);
    const requestedTime = req.body.requested_time;
    const quantity = Number(req.body.quantity || 1);
    const notes = req.body.notes || '';

    if (!factoryId || !materialId || !requestedTime) {
      return res.status(400).send('بيانات الطلب غير مكتملة');
    }

    const info = db.prepare(`
      INSERT INTO orders (factory_id, material_id, requested_time, quantity, notes, status, created_by)
      VALUES (?, ?, ?, ?, ?, 'جديد', ?)
    `).run(factoryId, materialId, requestedTime, quantity, notes, user.id);
    logAction(user.id, 'إنشاء طلب مصنع', 'orders', info.lastInsertRowid, notes);
    res.redirect('/factory/orders');
  } catch (err) {
    res.status(500).send('خطأ في حفظ طلب المصنع: ' + err.message);
  }
});

function renderPagesManager(req, res) {
  try {
    if (req.session.user.role !== 'admin') return res.status(403).send('غير مصرح');
    const pagesList = db.prepare('SELECT * FROM pages ORDER BY sort_order, id').all();
    res.render('pages', { title: 'إدارة الصفحات', user: req.session.user, currentPath: '/pages', pagesList });
  } catch (err) {
    res.status(500).send('خطأ في تحميل إدارة الصفحات: ' + err.message);
  }
}

app.get('/pages', requireAuth, renderPagesManager);

app.post('/pages', requireAuth, (req, res) => {
  try {
    if (req.session.user.role !== 'admin') return res.status(403).send('غير مصرح');
    const title = (req.body.title || '').trim();
    const rawSlug = (req.body.slug || '').trim().replace(/^\/+|\/+$/g, '');
    const slug = rawSlug.replace(/[^A-Za-z0-9_\-\u0600-\u06FF]/g, '-');
    if (!title || !slug) return res.status(400).send('عنوان الصفحة والرابط مطلوبان');
    const pathValue = '/' + slug;
    const pageKey = slug.toLowerCase();
    db.prepare(`
      INSERT INTO pages (page_key, title, path, icon, sort_order, is_active, is_system, content_html)
      VALUES (?, ?, ?, ?, ?, 1, 0, ?)
    `).run(pageKey, title, pathValue, req.body.icon || '📄', Number(req.body.sort_order || 200), req.body.content_html || '');
    res.redirect('/pages');
  } catch (err) {
    res.status(500).send('خطأ في إضافة الصفحة: ' + err.message);
  }
});

app.post('/pages/:id', requireAuth, (req, res) => {
  try {
    if (req.session.user.role !== 'admin') return res.status(403).send('غير مصرح');
    db.prepare(`
      UPDATE pages SET title = ?, icon = ?, sort_order = ?, is_active = ?, content_html = ?
      WHERE id = ?
    `).run(req.body.title || '', req.body.icon || '📄', Number(req.body.sort_order || 100), req.body.is_active ? 1 : 0, req.body.content_html || '', req.params.id);
    res.redirect('/pages');
  } catch (err) {
    res.status(500).send('خطأ في حفظ الصفحة: ' + err.message);
  }
});

app.delete('/pages/:id', requireAuth, (req, res) => {
  try {
    if (req.session.user.role !== 'admin') return res.status(403).send('غير مصرح');
    db.prepare('DELETE FROM pages WHERE id = ? AND is_system = 0').run(req.params.id);
    res.redirect('/pages');
  } catch (err) {
    res.status(500).send('خطأ في حذف الصفحة: ' + err.message);
  }
});


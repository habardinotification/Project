app.post('/api/truck-violations/save', (req, res) => {
  const { date, violations } = req.body;
  if (!date) return res.status(400).json({ error: 'التاريخ مطلوب' });
  try {
    const upsert = db.prepare(`
      INSERT INTO truck_violations (report_date, truck_number, driver_name, trips_count, reason, details, created_by)
      VALUES (?, ?, ?, ?, ?, ?, ?)
      ON CONFLICT(report_date, truck_number) DO UPDATE SET
        driver_name = excluded.driver_name,
        trips_count = excluded.trips_count,
        reason = excluded.reason,
        details = excluded.details,
        created_by = excluded.created_by,
        created_at = CURRENT_TIMESTAMP
    `);
    const tx = db.transaction((items) => {
      for (const v of items || []) {
        upsert.run(date, v.truckNumber || v.truck_number || '', v.driver || v.driver_name || '', Number(v.trips || v.trips_count || 0), v.reason || '', v.detail || v.details || '', req.session.user?.username || 'system');
      }
    });
    tx(violations || []);
    res.json({ success: true });
  } catch (err) { res.status(500).json({ error: err.message }); }
});

app.get('/api/truck-violations/report/:start/:end', (req, res) => {
  try {
    const rows = db.prepare(`
      SELECT report_date, truck_number, driver_name, trips_count, reason, details
      FROM truck_violations
      WHERE report_date BETWEEN ? AND ?
      ORDER BY report_date DESC, truck_number
    `).all(req.params.start, req.params.end);
    res.json(rows);
  } catch (err) { res.status(500).json({ error: err.message }); }
});

app.get('/api/truck-violations/stats/:start/:end', (req, res) => {
  try {
    const general = db.prepare(`
      SELECT COUNT(*) AS total_violations,
             COUNT(DISTINCT truck_number) AS total_trucks,
             COALESCE(AVG(trips_count), 0) AS avg_trips
      FROM truck_violations
      WHERE report_date BETWEEN ? AND ?
    `).get(req.params.start, req.params.end);
    const topTrucks = db.prepare(`
      SELECT truck_number, MAX(driver_name) AS driver_name, COUNT(*) AS violation_count, COALESCE(AVG(trips_count), 0) AS avg_trips
      FROM truck_violations
      WHERE report_date BETWEEN ? AND ?
      GROUP BY truck_number
      ORDER BY violation_count DESC, truck_number
      LIMIT 10
    `).all(req.params.start, req.params.end);
    const topReasons = db.prepare(`
      SELECT COALESCE(NULLIF(reason, ''), 'غير محدد') AS reason, COUNT(*) AS count
      FROM truck_violations
      WHERE report_date BETWEEN ? AND ?
      GROUP BY COALESCE(NULLIF(reason, ''), 'غير محدد')
      ORDER BY count DESC
      LIMIT 10
    `).all(req.params.start, req.params.end);
    res.json({ general, topTrucks, topReasons });
  } catch (err) { res.status(500).json({ error: err.message }); }
});

app.get('/api/backup', (req, res) => {

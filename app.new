// 4. إدارة المستخدمين
app.get('/api/users', (req, res) => {
  try {
    const users = db.prepare('SELECT id, username, name, role, factory_id, is_active, created_at FROM users ORDER BY id').all();
    res.json(users);
  } catch (err) { res.status(500).json({ error: err.message }); }
});
app.post('/api/users', (req, res) => {
  const { username, password, name, role, permissions } = req.body;
  if (!username || !password || !name) return res.status(400).json({ error: 'اسم المستخدم، كلمة المرور والاسم مطلوبة' });
  const hash = bcrypt.hashSync(password, 10);
  try {
    const stmt = db.prepare('INSERT INTO users (username, password_hash, name, role) VALUES (?, ?, ?, ?)');
    const info = stmt.run(username, hash, name, role || 'employee');
    res.json({ id: info.lastInsertRowid, username, name, role });
  } catch (err) { res.status(500).json({ error: err.message }); }
});
app.put('/api/users/:id', (req, res) => {
  const { name, role, password } = req.body;
  if (!name || !role) return res.status(400).json({ error: 'الاسم والدور مطلوبان' });
  try {
    if (password) {
      const hash = bcrypt.hashSync(password, 10);
      db.prepare('UPDATE users SET name = ?, role = ?, password_hash = ? WHERE id = ?').run(name, role, hash, req.params.id);
    } else {
      db.prepare('UPDATE users SET name = ?, role = ? WHERE id = ?').run(name, role, req.params.id);
    }
    res.json({ success: true });
  } catch (err) { res.status(500).json({ error: err.message }); }
});
app.delete('/api/users/:id', (req, res) => {
  try {
    const user = db.prepare('SELECT username FROM users WHERE id = ?').get(req.params.id);
    if (user?.username === 'Admin') return res.status(400).json({ error: 'لا يمكن حذف المدير الرئيسي' });
    db.prepare('DELETE FROM users WHERE id = ?').run(req.params.id);
    res.json({ success: true });
  } catch (err) { res.status(500).json({ error: err.message }); }
});

// 5. إدارة السجلات
app.get('/api/logs', (req, res) => {
  const page = parseInt(req.query.page) || 1;
  const limit = parseInt(req.query.limit) || 50;
  const offset = (page - 1) * limit;
  try {
    const total = db.prepare('SELECT COUNT(*) as count FROM logs').get().count;
    const logs = db.prepare(`
      SELECT l.*, u.username 
      FROM logs l
      LEFT JOIN users u ON l.user_id = u.id
      ORDER BY l.created_at DESC LIMIT ? OFFSET ?
    `).all(limit, offset);
    res.json({ logs, totalPages: Math.ceil(total / limit), currentPage: page });
  } catch (err) { res.status(500).json({ error: err.message }); }
});
app.get('/api/logs/all', (req, res) => {
  try {
    const logs = db.prepare(`SELECT l.*, u.username FROM logs l LEFT JOIN users u ON l.user_id = u.id ORDER BY l.created_at DESC`).all();
    res.json(logs);
  } catch (err) { res.status(500).json({ error: err.message }); }
});
app.delete('/api/logs/clear', (req, res) => {
  try {
    db.prepare('DELETE FROM logs').run();
    res.json({ success: true });
  } catch (err) { res.status(500).json({ error: err.message }); }
});

// 6. عمليات اليوم
app.get('/api/day/:date', (req, res) => {
  const targetDate = req.params.date;
  try {
    const start = `${targetDate} 00:00:00`, end = `${targetDate} 23:59:59`;
    const orders = db.prepare(`
      SELECT o.id, f.name as factory_name, m.name as material_name, o.requested_time, o.status
      FROM orders o
      LEFT JOIN factories f ON o.factory_id = f.id
      LEFT JOIN materials m ON o.material_id = m.id
      WHERE o.requested_time BETWEEN ? AND ?
    `).all(start, end);
    const formattedOrders = orders.map(o => ({
      id: o.id, factory: o.factory_name, material: o.material_name,
      time: o.requested_time ? new Date(o.requested_time).toLocaleTimeString('ar-EG') : '',
      timestamp: new Date(o.requested_time).toLocaleString('ar-EG')
    }));
    const distribution = db.prepare(`
      SELECT a.order_id, a.driver_id, a.truck_number, a.road, d.name as driver_name
      FROM assignments a
      LEFT JOIN drivers d ON a.driver_id = d.id
      WHERE DATE(a.created_at) = ?
    `).all(targetDate);
    res.json({ orders: formattedOrders, distribution });
  } catch (err) { res.status(500).json({ error: err.message }); }
});
app.put('/api/day/:date', (req, res) => {
  const targetDate = req.params.date;
  const { orders: updatedOrders, distribution } = req.body;
  const start = `${targetDate} 00:00:00`, end = `${targetDate} 23:59:59`;
  try {
    db.prepare('BEGIN').run();
    db.prepare(`DELETE FROM orders WHERE requested_time BETWEEN ? AND ?`).run(start, end);
    const ins = db.prepare(`INSERT INTO orders (factory_id, material_id, requested_time, status, notes, created_at) VALUES (?, ?, ?, ?, ?, datetime('now'))`);
    for (const ord of updatedOrders) {
      const factory = db.prepare('SELECT id FROM factories WHERE name = ?').get(ord.factory);
      const material = db.prepare('SELECT id FROM materials WHERE name = ?').get(ord.material);
      if (!factory || !material) continue;
      let dt = `${targetDate} ${ord.time || '12:00:00'}`;
      if (ord.time && ord.time.includes(':')) dt = `${targetDate} ${ord.time}`;
      ins.run(factory.id, material.id, dt, 'pending', ord.notes || '');
    }
    if (distribution && distribution.length) {
      db.prepare('DELETE FROM assignments WHERE DATE(created_at) = ?').run(targetDate);
      const insAssign = db.prepare('INSERT INTO assignments (order_id, driver_id, truck_number, road, created_at) VALUES (?, ?, ?, ?, datetime("now"))');
      for (const d of distribution) {
        const driver = db.prepare('SELECT id FROM drivers WHERE name = ?').get(d.driver_name);
        insAssign.run(d.orderId, driver?.id || null, d.truck?.number || '', d.road || 1);
      }
    }
    db.prepare('COMMIT').run();
    res.json({ success: true });
  } catch (err) { db.prepare('ROLLBACK').run(); res.status(500).json({ error: err.message }); }
});

// 7. بيانات لوحة التحكم (للتحديث التلقائي) - تم تعديلها أيضاً
app.get('/api/dashboard-data', (req, res) => {
  try {
    const stats = getDashboardStats();
    // FIXED: إزالة join مع drivers و trucks (نفس تعديل الصفحة الرئيسية)
    const recentOrders = db.prepare(`
      SELECT o.id, o.requested_time, o.status, f.name as factory_name, m.name as material_name
      FROM orders o
      LEFT JOIN factories f ON o.factory_id = f.id
      LEFT JOIN materials m ON o.material_id = m.id
      ORDER BY o.created_at DESC LIMIT 5
    `).all();
    const factoryStats = db.prepare(`SELECT f.name, COUNT(o.id) as count FROM orders o LEFT JOIN factories f ON o.factory_id = f.id GROUP BY f.name`).all();
    const materialStats = db.prepare(`SELECT m.name, COUNT(o.id) as count FROM orders o LEFT JOIN materials m ON o.material_id = m.id GROUP BY m.name`).all();
    const overdueOrders = db.prepare(`SELECT id FROM orders WHERE datetime(requested_time) < datetime('now') AND status NOT IN ('completed','cancelled')`).all();
    res.json({
      stats, recentOrders,
      factoryStats: factoryStats.reduce((a,b)=>(a[b.name]=b.count,a),{}),
      materialStats: materialStats.reduce((a,b)=>(a[b.name]=b.count,a),{}),
      overdueOrders
    });
  } catch (err) { res.status(500).json({ error: err.message }); }
});


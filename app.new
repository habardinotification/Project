app.get('/:slug', requireAuth, (req, res, next) => {
  try {
    const requestPath = '/' + req.params.slug;
    const page = db.prepare('SELECT * FROM pages WHERE path = ? AND is_active = 1 LIMIT 1').get(requestPath);
    if (!page || page.is_system) return next();
    if (!canAccessPage(req.session.user, requestPath)) return res.status(403).send('غير مصرح');
    res.render('custom_page', {
      title: page.title,
      user: req.session.user,
      currentPath: requestPath,
      page
    });
  } catch (err) {
    next(err);
  }
});


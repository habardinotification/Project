function syncSystemPages() {
  const systemPages = [
    ['main_site', 'الموقع الرئيسي', '/main-site/index.html', '🌐', 5],
    ['dashboard', '\u0627\u0644\u0631\u0626\u064a\u0633\u064a\u0629', '/dashboard', '\ud83d\udcca', 10],
    ['orders', '\u0627\u0644\u0637\u0644\u0628\u0627\u062a', '/orders', '\ud83d\udcdd', 20],
    ['factory_orders', '\u0637\u0644\u0628\u0627\u062a \u0627\u0644\u0645\u0635\u0646\u0639', '/factory_orders', '\ud83c\udfed', 25],
    ['distribution', '\u0627\u0644\u062a\u0648\u0632\u064a\u0639', '/distribution', '\ud83d\ude9a', 30],
    ['distribution_quality', '\u062c\u0648\u062f\u0629 \u0627\u0644\u062a\u0648\u0632\u064a\u0639', '/distribution-quality', '\ud83d\udcca', 35],
    ['drivers', '\u0627\u0644\u0633\u0627\u0626\u0642\u064a\u0646', '/drivers', '\ud83d\udc68\u200d\u2708\ufe0f', 40],
    ['trucks', '\u0627\u0644\u0633\u064a\u0627\u0631\u0627\u062a', '/trucks', '\ud83d\ude9b', 45],
    ['trucks_failed', '\u0627\u0644\u0633\u064a\u0627\u0631\u0627\u062a \u063a\u064a\u0631 \u0627\u0644\u0645\u0633\u062a\u0648\u0641\u064a\u0629', '/trucks-failed', '\u26a0\ufe0f', 50],
    ['trucks_failed_report', '\u062a\u0642\u0631\u064a\u0631 \u0627\u0644\u0645\u062e\u0627\u0644\u0641\u0627\u062a', '/trucks-failed-report', '\ud83d\udccb', 55],
    ['expenses', '\u0645\u0635\u0627\u0631\u064a\u0641 \u0627\u0644\u0633\u064a\u0627\u0631\u0627\u062a', '/expenses', '\ud83d\udcb0', 60],
    ['materials', '\u0623\u0646\u0648\u0627\u0639 \u0627\u0644\u0628\u062d\u0635', '/materials', '\ud83d\udce6', 70],
    ['factories', '\u0627\u0644\u0645\u0635\u0627\u0646\u0639', '/factories', '\ud83c\udfed', 80],
    ['cash_orders', '\u0627\u0644\u0637\u0644\u0628\u0627\u062a \u0627\u0644\u0646\u0642\u062f\u064a\u0629', '/cash-orders', '\ud83d\udcb5', 90],
    ['reports', '\u062a\u0642\u0627\u0631\u064a\u0631 \u0627\u0644\u0643\u0633\u0627\u0631\u0629', '/reports', '\ud83d\udcc8', 100],
    ['scale_report', '\u062a\u0642\u0627\u0631\u064a\u0631 \u0627\u0644\u0645\u064a\u0632\u0627\u0646', '/scale_report', '\u2696\ufe0f', 110],
    ['blocks', '\u0627\u0644\u062d\u0638\u0631', '/blocks', '\u26d4', 120],
    ['users', '\u0627\u0644\u0645\u0633\u062a\u062e\u062f\u0645\u064a\u0646', '/users', '\ud83d\udc65', 130],
    ['logs', '\u0627\u0644\u0633\u062c\u0644\u0627\u062a', '/logs', '\ud83d\udcdc', 140],
    ['settings', '\u0627\u0644\u0625\u0639\u062f\u0627\u062f\u0627\u062a', '/settings', '\u2699\ufe0f', 150],
    ['pages', '\u0625\u062f\u0627\u0631\u0629 \u0627\u0644\u0635\u0641\u062d\u0627\u062a', '/pages', '\ud83e\udde9', 160],
    ['contact', '\u0627\u062a\u0635\u0644 \u0628\u0646\u0627', '/contact', '\u260e\ufe0f', 170]
  ];
  const select = db.prepare('SELECT id FROM pages WHERE page_key = ?');
  const insert = db.prepare('INSERT INTO pages (page_key, title, path, icon, sort_order, is_active, is_system, content_html) VALUES (?, ?, ?, ?, ?, 1, 1, ?)');
  const update = db.prepare('UPDATE pages SET title = ?, path = ?, icon = ?, sort_order = ?, is_active = 1, is_system = 1 WHERE page_key = ?');
  for (const [key, title, routePath, icon, sort] of systemPages) {
    const existing = select.get(key);
    if (existing) update.run(title, routePath, icon, sort, key);
    else insert.run(key, title, routePath, icon, sort, '');
  }
}
syncSystemPages();

function loadAutoPages() {
  const autoDir = path.join(__dirname, 'views', 'auto_pages');
  if (!fs.existsSync(autoDir)) return [];
  return fs.readdirSync(autoDir)
    .filter(file => file.endsWith('.ejs'))
    .map(file => {
      const slug = file.replace(/\.ejs$/, '');
      const fullPath = path.join(autoDir, file);
      const content = fs.readFileSync(fullPath, 'utf8');
      const title = (content.match(/<!--\s*title:\s*(.*?)\s*-->/i) || [])[1] || slug;
      const icon = (content.match(/<!--\s*icon:\s*(.*?)\s*-->/i) || [])[1] || '\ud83d\udcc4';
      const sort = Number((content.match(/<!--\s*sort:\s*(.*?)\s*-->/i) || [])[1] || 300);
      return { slug, view: `auto_pages/${slug}`, path: `/auto-pages/${slug}`, title, icon, sort };
    })
    .sort((a, b) => a.sort - b.sort || a.title.localeCompare(b.title, 'ar'));
}

function getCustomSidebarPagesForUser(user) {
  if (!user) return [];
  try {
    return getSidebarPages(user).filter(p => !p.is_system && p.is_active);
  } catch (e) {
    return [];
  }
}

const autoPages = loadAutoPages();

app.use((req, res, next) => {
  res.locals.autoPages = autoPages;
  res.locals.customSidebarPages = getCustomSidebarPagesForUser(req.session && req.session.user);
  next();
});

// إضافة جدول القيود (restrictions) إذا لم يكن موجوداً
const createRestrictionsTable = () => {
  db.exec(`
    CREATE TABLE IF NOT EXISTS restrictions (
      id INTEGER PRIMARY KEY AUTOINCREMENT,
      truck_number TEXT NOT NULL,
      driver_name TEXT,
      restricted_factories TEXT,
      reason TEXT,
      active INTEGER DEFAULT 1,
      created_at TEXT DEFAULT CURRENT_TIMESTAMP,
      created_by TEXT
    )
  `);
};
createRestrictionsTable();

// ======================
// دوال مساعدة عامة
// ======================
function getDashboardStats() {
  const ordersCount = db.prepare("SELECT COUNT(*) as count FROM orders").get().count;
  const pendingCount = db.prepare("SELECT COUNT(*) as count FROM orders WHERE status != 'completed' AND status != 'cancelled'").get().count;
  const completedCount = db.prepare("SELECT COUNT(*) as count FROM orders WHERE status = 'completed'").get().count;
  const driversCount = db.prepare("SELECT COUNT(*) as count FROM drivers WHERE status != 'deleted'").get().count;
  const availableDrivers = db.prepare("SELECT COUNT(*) as count FROM drivers WHERE status = 'available'").get().count;
  const factoriesCount = db.prepare("SELECT COUNT(*) as count FROM factories WHERE is_active = 1").get().count;
  const materialsCount = db.prepare("SELECT COUNT(*) as count FROM materials WHERE is_active = 1").get().count;
  const trucksCount = db.prepare("SELECT COUNT(*) as count FROM trucks").get().count;
  const today = new Date().toISOString().slice(0,10);
  const distributedTrips = db.prepare(`SELECT COUNT(DISTINCT order_id) as count FROM assignments WHERE DATE(created_at) = ?`).get(today)?.count || 0;
  const activeTrucks = db.prepare(`SELECT COUNT(DISTINCT driver_id) as count FROM assignments WHERE DATE(created_at) = ?`).get(today)?.count || 0;
  return {
    orders: ordersCount, pending: pendingCount, completed: completedCount,
    drivers: driversCount, available: availableDrivers, trucks: trucksCount,
    factories: factoriesCount, materials: materialsCount,
    totalOrders: ordersCount, distributedTrips, activeTrucks
  };
}

function requireAuth(req, res, next) {
  if (!req.session.user) return res.redirect('/login');
  next();
}

// ======================
// المسارات الرئيسية (الصفحات)
// ======================

app.get('/login', (req, res) => {
  if (req.session.user) return res.redirect('/');
  res.render('login', { title: 'تسجيل الدخول', flash: null, layout: false });
});

app.post('/login', (req, res) => {
  const { username, password } = req.body;
  if (!username || !password) {
    return res.render('login', { title: 'تسجيل الدخول', flash: { type: 'error', message: 'يرجى إدخال اسم المستخدم وكلمة السر' }, layout: false });
  }
  const user = db.prepare('SELECT * FROM users WHERE username = ?').get(username);
  if (!user || !bcrypt.compareSync(password, user.password_hash)) {
    return res.render('login', { title: 'تسجيل الدخول', flash: { type: 'error', message: 'بيانات غير صحيحة' }, layout: false });
  }
  req.session.user = {
    id: user.id,
    username: user.username,
    name: user.name,
    role: user.role,
    factory_id: user.factory_id
  };
  res.redirect('/');
});

app.get('/logout', (req, res) => {
  req.session.destroy(() => res.redirect('/login'));
});

// الصفحة الرئيسية (Dashboard) - مع تصحيح الاستعلام (تمت إزالة driver و truck)
function renderDashboard(req, res) {
  const stats = getDashboardStats();
  const recentOrders = db.prepare(`
    SELECT o.id, o.requested_time, o.status, f.name as factory_name, m.name as material_name
    FROM orders o
    LEFT JOIN factories f ON o.factory_id = f.id
    LEFT JOIN materials m ON o.material_id = m.id
    ORDER BY o.created_at DESC LIMIT 5
  `).all();
  res.render('dashboard', {
    title: '\u0627\u0644\u0631\u0626\u064a\u0633\u064a\u0629',
    user: req.session.user,
    stats: stats,
    recentOrders: recentOrders,
    currentPath: req.path === '/dashboard' ? '/dashboard' : '/'
  });
}
app.get('/', requireAuth, renderDashboard);
app.get('/dashboard', requireAuth, renderDashboard);


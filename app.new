const storage = multer.diskStorage({
  destination: (req, file, cb) => {
    const dir = path.join(__dirname, 'uploads');
    if (!fs.existsSync(dir)) fs.mkdirSync(dir);
    cb(null, dir);
  },
  filename: (req, file, cb) => cb(null, Date.now() + '-' + file.originalname)
});
const upload = multer({ storage: storage });

db.exec(`CREATE TABLE IF NOT EXISTS expense_reports (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  filename TEXT,
  report_name TEXT,
  report_date TEXT,
  data TEXT,
  uploaded_by TEXT,
  uploaded_at TEXT DEFAULT CURRENT_TIMESTAMP
)`);
db.exec(`CREATE TABLE IF NOT EXISTS uploaded_files (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  original_name TEXT,
  stored_name TEXT,
  report_name TEXT,
  uploaded_by TEXT,
  uploaded_at TEXT DEFAULT CURRENT_TIMESTAMP
)`);

db.exec(`CREATE TABLE IF NOT EXISTS truck_violations (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  report_date TEXT NOT NULL,
  truck_number TEXT NOT NULL,
  driver_name TEXT DEFAULT '',
  trips_count INTEGER DEFAULT 0,
  reason TEXT DEFAULT '',
  details TEXT DEFAULT '',
  created_by TEXT DEFAULT '',
  created_at TEXT DEFAULT CURRENT_TIMESTAMP,
  UNIQUE(report_date, truck_number)
)`);

app.post('/api/upload-excel-report', upload.single('excelFile'), (req, res) => {
  const { reportName, reportDate, vehicleData } = req.body;
  const file = req.file;
  if (!file) return res.status(400).json({ error: 'الملف مطلوب' });
  try {
    const stmt = db.prepare('INSERT INTO expense_reports (filename, report_name, report_date, data, uploaded_by) VALUES (?, ?, ?, ?, ?)');
    stmt.run(file.filename, reportName, reportDate, vehicleData, req.session.user?.username || 'system');
    const stmt2 = db.prepare('INSERT INTO uploaded_files (original_name, stored_name, report_name, uploaded_by) VALUES (?, ?, ?, ?)');
    stmt2.run(file.originalname, file.filename, reportName, req.session.user?.username || 'system');
    res.json({ success: true });
  } catch (err) { res.status(500).json({ error: err.message }); }
});


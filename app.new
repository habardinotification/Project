app.get('/auto-pages/:slug', requireAuth, (req, res, next) => {
  const page = autoPages.find(p => p.slug === req.params.slug);
  if (!page) return next();
  res.render(page.view, {
    title: page.title,
    user: req.session.user,
    currentPath: page.path
  });
});

// ======================
// واجهات API (مع تصحيح الاستعلامات المشابهة)
// ======================

// 1. معلومات المستخدم الحالي
app.get('/api/me', (req, res) => {
  if (!req.session.user) return res.status(401).json({ error: 'غير مصرح' });
  const user = req.session.user;
  let permissions = {};
  if (user.role === 'admin') {
    permissions = {
      viewOrders: true, addOrders: true, editOrders: true, deleteOrders: true,
      viewDistribution: true, manageDistribution: true, viewTrucks: true, manageTrucks: true,
      viewDrivers: true, manageDrivers: true, viewSettings: true, viewReports: true,
      exportReports: true, manageRestrictions: true, manageUsers: true, viewBackup: true
    };
  } else if (user.role === 'employee') {
    permissions = { viewOrders: true, addOrders: true, editOrders: true, deleteOrders: false };
  } else if (user.role === 'factory') {
    permissions = { viewOrders: true, addOrders: true, editOrders: true, deleteOrders: true };
  }
  res.json({ user: { ...user, permissions } });
});

// 2. الإعدادات العامة
app.get('/api/settings', (req, res) => {
  try {
    const factories = db.prepare(`
      SELECT id, name, distance_km AS distance, city AS location, priority_level, priority_label, is_active
      FROM factories
      WHERE is_active = 1
      ORDER BY name
    `).all();
    const materials = db.prepare('SELECT name FROM materials WHERE is_active = 1 ORDER BY name').all().map(m => m.name);
    const trucks = db.prepare('SELECT id, plate_number as number, model, status, driver_name as driver FROM trucks ORDER BY plate_number').all();
    const drivers = db.prepare(`
      SELECT d.*, t.plate_number AS current_truck
      FROM drivers d
      LEFT JOIN trucks t ON d.current_truck_id = t.id
      ORDER BY d.name
    `).all();
    res.json({ factories, materials, trucks, drivers });
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

app.put('/api/settings', (req, res) => {
  const { factories, materials, trucks } = req.body;
  try {
    db.prepare('DELETE FROM factories').run();
    const insFact = db.prepare('INSERT INTO factories (name, is_active, distance_km, city) VALUES (?, 1, ?, ?)');
    (factories || []).forEach(f => insFact.run(f.name || f, Number(f.distance || f.distance_km || 0), f.location || f.city || ''));
    db.prepare('DELETE FROM materials').run();
    const insMat = db.prepare('INSERT INTO materials (name, is_active) VALUES (?, 1)');
    (materials || []).forEach(m => insMat.run(m.name || m));
    db.prepare('DELETE FROM trucks').run();
    const insTruck = db.prepare('INSERT INTO trucks (plate_number, model, status, driver_name) VALUES (?, ?, ?, ?)');
    (trucks || []).forEach(t => insTruck.run(t.number || t.plate_number, t.model || '', t.status || 'available', t.driver || t.driver_name || ''));
    res.json({ success: true });
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});


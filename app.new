  resave: false,
  saveUninitialized: false,
  cookie: { secure: false, maxAge: 24 * 60 * 60 * 1000 }
}));

// ======================
// متغيرات عامة للـ layout
// ======================
app.locals.systemName = process.env.SYSTEM_NAME || 'شركة زرعة الخير للنقليات / فرع الكسارة';
app.locals.companyName = process.env.COMPANY_NAME || 'مجموعة زرعة الخير للتطوير والاستثمار العقاري';
app.locals.formatDate = function(dateStr) {
  if (!dateStr) return '-';
  const d = new Date(dateStr);
  return d.toLocaleString('ar-EG');
};


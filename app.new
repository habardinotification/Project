app.post('/api/restore', (req, res) => {
  const data = req.body || {};
  try {
    const tx = db.transaction(() => {
      if (data.settings) {
        if (Array.isArray(data.settings.factories)) {
          db.prepare('DELETE FROM factories').run();
          const ins = db.prepare('INSERT INTO factories (name, is_active, distance_km, city) VALUES (?, ?, ?, ?)');
          data.settings.factories.forEach(f => ins.run(f.name || String(f), f.is_active ?? 1, f.distance_km || 0, f.city || f.location || ''));
        }
        if (Array.isArray(data.settings.materials)) {
          db.prepare('DELETE FROM materials').run();
          const ins = db.prepare('INSERT INTO materials (name, is_active) VALUES (?, ?)');
          data.settings.materials.forEach(m => ins.run(m.name || String(m), m.is_active ?? 1));
        }
        if (Array.isArray(data.settings.trucks)) {
          db.prepare('DELETE FROM trucks').run();
          const ins = db.prepare('INSERT INTO trucks (plate_number, model, status, driver_name) VALUES (?, ?, ?, ?)');
          data.settings.trucks.forEach(t => ins.run(t.plate_number || t.number || String(t), t.model || '', t.status || 'available', t.driver_name || t.driver || ''));
        }
      }
      if (Array.isArray(data.truckViolations)) {
        db.prepare('DELETE FROM truck_violations').run();
        const ins = db.prepare('INSERT OR REPLACE INTO truck_violations (report_date, truck_number, driver_name, trips_count, reason, details, created_by) VALUES (?, ?, ?, ?, ?, ?, ?)');
        data.truckViolations.forEach(v => ins.run(v.report_date, v.truck_number, v.driver_name || '', v.trips_count || 0, v.reason || '', v.details || '', v.created_by || 'restore'));
      }
    });
    tx();
    res.json({ success: true });
  } catch (err) { res.status(500).json({ error: err.message }); }
});

app.delete('/api/clear-all', (req, res) => {
  try {
    const tx = db.transaction(() => {
      db.prepare('DELETE FROM assignments').run();
      db.prepare('DELETE FROM orders').run();
      db.prepare('DELETE FROM expense_reports').run();
      db.prepare('DELETE FROM uploaded_files').run();
      db.prepare('DELETE FROM truck_violations').run();
      db.prepare('DELETE FROM restrictions').run();
    });
    tx();
    res.json({ success: true });
  } catch (err) { res.status(500).json({ error: err.message }); }
});

